@{
    Layout = "~/Views/Shared/_TenantLayout.cshtml";
}


<div class="min-h-screen bg-slate-100" ng-init="init()">
    <!-- Header -->
    <header class="bg-slate-900 text-white px-4 sm:px-8 py-4 flex items-center justify-between shadow-md">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
                <lucide-icon name="building-2" size="16" class="text-white"></lucide-icon>
            </div>
            <span class="text-lg font-bold">
                Green<span class="text-green-400">Residences</span>
                <span class="text-slate-400 text-xs ml-1.5">Tenant Portal</span>
            </span>
        </div>
        <div class="flex items-center gap-3">
            <div class="hidden sm:flex items-center gap-2">
                <div class="w-7 h-7 rounded-full bg-green-600 flex items-center justify-center text-white text-xs font-bold">
                    {{ currentTenant.name[0] }}
                </div>
                <span class="text-sm text-slate-300">{{ currentTenant.name }}</span>
            </div>
            <button ng-click="handleLogout()"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-800 hover:bg-red-900/50 text-slate-300 hover:text-red-300 text-sm transition-all">
                <lucide-icon name="log-out" size="14"></lucide-icon> Logout
            </button>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 py-8 space-y-6">

        <!-- ── Welcome card ── -->
        <div class="bg-gradient-to-r from-green-600 to-green-700 rounded-2xl p-6 text-white shadow-lg shadow-green-200 fade-in-up">
            <div class="flex items-start justify-between flex-wrap gap-4">
                <div>
                    <p class="text-green-200 text-sm mb-1">
                        Welcome back, Tenant
                        <span class="text-white"> {{ currentTenant.id | uppercase }}</span>
                    </p>
                    <h2 class="text-white mb-3 text-2xl font-bold">{{ currentTenant.name }}</h2>
                    <div class="flex flex-wrap items-center gap-3 text-sm">
                        <span class="flex items-center gap-1.5 bg-white/15 px-3 py-1 rounded-full">
                            <lucide-icon name="building-2" size="13"></lucide-icon> {{ currentTenant.unit }}
                        </span>

                        <app-status-badge status="liveStatus"></app-status-badge>

                        <span ng-if="latestPayment"
                              class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium"
                              ng-class="{
                    'bg-emerald-500/20 text-emerald-200': latestPayment.status === 'Paid',
                    'bg-red-500/20 text-red-200': latestPayment.status === 'Overdue',
                    'bg-amber-500/20 text-amber-200': latestPayment.status !== 'Paid' && latestPayment.status !== 'Overdue'
                  }">
                            <lucide-icon name="credit-card" size="11"></lucide-icon>
                            {{ latestPayment.status === 'Paid' ? 'Rent Paid' : (latestPayment.status === 'Overdue' ? 'Rent Overdue' : 'Rent Pending') }}
                        </span>
                    </div>
                </div>

                <div ng-if="daysLeft !== null" class="bg-white/15 rounded-xl px-5 py-3 text-center">
                    <p class="text-green-200 text-xs mb-0.5">Lease ends in</p>
                    <p class="text-3xl font-bold text-white">{{ daysLeft < 0 ? 0 : daysLeft }}</p>
                    <p class="text-green-200 text-xs">days</p>
                </div>
            </div>
        </div>

        <!-- ── Lease Info ── -->
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 fade-in-up delay-1">
            <div class="flex items-center gap-2 mb-4">
                <lucide-icon name="calendar" size="18" class="text-green-600"></lucide-icon>
                <h3 class="text-slate-900 font-semibold">Lease Details</h3>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                <div class="bg-slate-50 rounded-xl p-3">
                    <p class="text-slate-400 text-xs mb-0.5">Unit</p>
                    <p class="text-slate-900 text-sm font-medium">{{ currentTenant.unit || '—' }}</p>
                </div>
                <div class="bg-slate-50 rounded-xl p-3">
                    <p class="text-slate-400 text-xs mb-0.5">Lease Start</p>
                    <p class="text-slate-900 text-sm font-medium">{{ currentTenant.leaseStart || '—' }}</p>
                </div>
                <div class="bg-slate-50 rounded-xl p-3">
                    <p class="text-slate-400 text-xs mb-0.5">Lease End</p>
                    <p class="text-slate-900 text-sm font-medium">{{ currentTenant.leaseEnd || '—' }}</p>
                </div>
                <div class="bg-slate-50 rounded-xl p-3">
                    <p class="text-slate-400 text-xs mb-0.5">Days Remaining</p>
                    <p class="text-slate-900 text-sm font-medium">
                        {{ daysLeft !== null ? (daysLeft < 0 ? 'Expired' : daysLeft + ' days') : '—' }}
                    </p>
                </div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mt-4">
                <div class="bg-slate-50 rounded-xl p-3">
                    <p class="text-slate-400 text-xs mb-0.5">Phone</p>
                    <p class="text-slate-900 text-sm font-medium">{{ currentTenant.phone || '—' }}</p>
                </div>
                <div class="bg-slate-50 rounded-xl p-3">
                    <p class="text-slate-400 text-xs mb-0.5">Address</p>
                    <p class="text-slate-900 text-sm font-medium">{{ currentTenant.address || '—' }}</p>
                </div>
                <div class="bg-slate-50 rounded-xl p-3">
                    <p class="text-slate-400 text-xs mb-0.5">Occupation</p>
                    <p class="text-slate-900 text-sm font-medium">{{ currentTenant.occupation || '—' }}</p>
                </div>
            </div>
        </div>

        <!-- ── Co-occupants ── -->
        <div ng-if="hasCoOccupants" class="bg-white rounded-2xl border border-blue-100 shadow-sm p-6 fade-in-up delay-2">
            <div class="flex items-center gap-2 mb-4">
                <lucide-icon name="users" size="18" class="text-blue-600"></lucide-icon>
                <h3 class="text-slate-900 font-semibold">Co-occupants</h3>
                <span class="ml-auto text-xs text-slate-400">
                    {{ currentTenant.additionalOccupants.length }} additional occupant{{ currentTenant.additionalOccupants.length !== 1 ? 's' : '' }}
                </span>
            </div>

            <div class="space-y-3">
                <div ng-repeat="occ in currentTenant.additionalOccupants track by $index" class="flex items-start gap-3 p-3.5 bg-blue-50 border border-blue-100 rounded-xl">
                    <div class="w-9 h-9 bg-blue-100 rounded-full flex items-center justify-center text-blue-700 font-bold text-sm flex-shrink-0">
                        {{ occ.name ? occ.name[0] : '?' }}
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-slate-900 text-sm font-semibold">{{ occ.name }}</p>
                        <div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-1">
                            <span class="text-xs text-slate-500 flex items-center gap-1">
                                <lucide-icon name="phone" size="10" class="text-blue-400"></lucide-icon>
                                {{ occ.phone || '—' }}
                            </span>
                            <span ng-if="occ.address" class="text-xs text-slate-500 flex items-center gap-1">
                                <lucide-icon name="map-pin" size="10" class="text-blue-400"></lucide-icon>
                                {{ occ.address }}
                            </span>
                        </div>
                    </div>
                    <span class="text-xs text-blue-500 bg-blue-100 px-2 py-0.5 rounded-full flex-shrink-0">
                        #{{ $index + 1 }}
                    </span>
                </div>
            </div>
        </div>

        <!-- ── Payment History ── -->
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 fade-in-up delay-3">
            <div class="flex items-center gap-2 mb-5">
                <lucide-icon name="credit-card" size="18" class="text-green-600"></lucide-icon>
                <h3 class="text-slate-900 font-semibold">Payment History</h3>
                <span ng-if="myPayments.length > 0" class="ml-auto text-xs text-slate-400">
                    {{ paidPaymentsCount }} of {{ myPayments.length }} paid
                </span>
            </div>

            <p ng-if="myPayments.length === 0" class="text-slate-400 text-sm text-center py-6">
                No payment records found.
            </p>

            <div ng-if="myPayments.length > 0" class="relative">
                <div class="absolute left-[22px] top-2 bottom-2 w-0.5 bg-slate-100 rounded-full"></div>
                <div class="space-y-3">

                    <div ng-repeat="p in myPayments" class="flex items-start gap-4">
                        <div class="relative z-10 w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0 shadow-sm"
                             ng-class="{'bg-emerald-100': p.status === 'Paid', 'bg-red-100': p.status === 'Overdue', 'bg-amber-100': p.status !== 'Paid' && p.status !== 'Overdue'}">
                            <lucide-icon ng-if="p.status === 'Paid'" name="check-circle" size="15" class="text-emerald-500"></lucide-icon>
                            <lucide-icon ng-if="p.status === 'Overdue'" name="x-circle" size="15" class="text-red-500"></lucide-icon>
                            <lucide-icon ng-if="p.status !== 'Paid' && p.status !== 'Overdue'" name="alert-circle" size="15" class="text-amber-500"></lucide-icon>
                        </div>

                        <div class="flex-1 rounded-xl p-3.5" ng-class="getPaymentRowClass(p.status)">
                            <div class="flex items-start justify-between gap-2">
                                <div>
                                    <p class="text-slate-900 text-sm font-semibold">{{ p.month }}</p>
                                    <div class="flex flex-wrap gap-3 mt-1 text-xs text-slate-500">
                                        <span>Due: {{ p.dueDate }}</span>
                                        <span ng-if="p.paidDate" class="text-emerald-600 font-medium">
                                            ✓ Paid: {{ p.paidDate }}
                                        </span>
                                    </div>
                                </div>
                                <div class="text-right flex-shrink-0">
                                    <p class="text-slate-900 text-sm font-bold">₱{{ p.amount | number }}</p>
                                    <span class="inline-block mt-1 text-xs px-2 py-0.5 rounded-full font-medium"
                                          ng-class="getPaymentBadgeClass(p.status)">
                                        {{ p.status }}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Payment Summary Footer -->
                <div class="mt-5 pt-4 border-t border-slate-100 grid grid-cols-3 gap-3 text-center">
                    <div class="bg-slate-50 rounded-xl py-2">
                        <p class="text-lg font-bold text-emerald-600">{{ paidPaymentsCount }}</p>
                        <p class="text-xs text-slate-400">Paid</p>
                    </div>
                    <div class="bg-slate-50 rounded-xl py-2">
                        <p class="text-lg font-bold text-amber-600">{{ unpaidPaymentsCount }}</p>
                        <p class="text-xs text-slate-400">Unpaid</p>
                    </div>
                    <div class="bg-slate-50 rounded-xl py-2">
                        <p class="text-lg font-bold text-red-600">{{ overduePaymentsCount }}</p>
                        <p class="text-xs text-slate-400">Overdue</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Maintenance Requests ── -->
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 fade-in-up delay-4 mb-8">
            <div class="flex items-center justify-between mb-5">
                <div class="flex items-center gap-2">
                    <lucide-icon name="wrench" size="18" class="text-green-600"></lucide-icon>
                    <h3 class="text-slate-900 font-semibold">Maintenance Requests</h3>
                </div>
                <button ng-click="toggleRequestForm()"
                        class="flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-medium transition-all focus:outline-none focus:ring-2 focus:ring-green-500"
                        ng-class="showRequestForm ? 'bg-slate-100 text-slate-600' : 'bg-green-600 hover:bg-green-700 text-white shadow-sm shadow-green-200'">
                    <lucide-icon ng-if="showRequestForm" name="chevron-up" size="14"></lucide-icon>
                    <span ng-if="showRequestForm">Cancel</span>

                    <lucide-icon ng-if="!showRequestForm" name="plus" size="14"></lucide-icon>
                    <span ng-if="!showRequestForm">New Request</span>
                </button>
            </div>

            <!-- Expandable Form -->
            <div ng-if="showRequestForm" class="overflow-hidden">
                <form ng-submit="handleSubmitRequest($event)" class="bg-green-50 border border-green-100 rounded-2xl p-5 mb-5 space-y-4">
                    <p class="text-sm text-green-800 font-medium">Submit a New Request</p>

                    <!-- Category -->
                    <div>
                        <label class="block text-xs text-slate-600 font-medium mb-1.5">Category *</label>
                        <select name="reqCategory"
                                ng-model="$parent.reqCategory""
                                class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
                            <option ng-repeat="c in MAINTENANCE_CATEGORIES" value="{{ c }}">{{ c }}</option>
                        </select>
                    </div>

                    <!-- Description -->
                    <div>
                        <label class="block text-xs text-slate-600 font-medium mb-1.5">
                            Description * <span class="text-slate-400 font-normal">(describe the issue clearly)</span>
                        </label>
                        <textarea name="reqDescription"
                                  ng-model="$parent.reqDescription""
                                  rows="4"
                                  placeholder="e.g. The bathroom faucet has been leaking since yesterday morning..."
                                  class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-white text-sm resize-none focus:outline-none focus:ring-2 focus:ring-green-500"></textarea>
                        <p class="text-xs text-slate-400 mt-1">{{ reqDescription.length }}/100 characters</p>
                    </div>

                    <!-- Photo Upload -->
                    <!--<div>
                        <label class="block text-xs text-slate-600 font-medium mb-1.5">
                            Photo <span class="text-slate-400 font-normal">(optional, max 5MB)</span>
                        </label>

                        <div ng-if="reqPhoto" class="relative rounded-xl overflow-hidden border border-green-200 bg-white">
                            <img ng-src="{{ reqPhoto }}" alt="Preview" class="w-full max-h-48 object-cover" />
                            <div class="absolute top-2 right-2 flex items-center gap-2">
                                <span class="text-xs bg-black/50 text-white px-2 py-0.5 rounded-full truncate max-w-[140px]">
                                    {{ reqPhotoName }}
                                </span>
                                <button type="button"
                                        ng-click="handleRemovePhoto()"
                                        class="w-6 h-6 bg-red-500 hover:bg-red-600 text-white rounded-full flex items-center justify-center transition-all">
                                    <lucide-icon name="x" size="12"></lucide-icon>
                                </button>
                            </div>
                        </div>

                        <button ng-if="!reqPhoto"
                                type="button"
                                ng-click="triggerPhotoUpload()"
                                class="w-full flex flex-col items-center justify-center gap-2 py-5 border-2 border-dashed border-green-200 rounded-xl bg-white hover:bg-green-50 hover:border-green-300 transition-all text-slate-500 hover:text-green-700">
                            <lucide-icon name="image" size="20" class="text-green-400"></lucide-icon>
                            <span class="text-xs font-medium">Click to upload a photo</span>
                            <span class="text-xs text-slate-400">JPG, PNG, WEBP up to 5MB</span>
                        </button>-->

                        <!-- In AngularJS, custom file input changes are often handled via onchange mapping to scope -->
                        <!--<input id="photoInput"
                               type="file"
                               accept="image/*"
                               class="hidden"
                               onchange="angular.element(this).scope().handlePhotoChange(event)" />
                    </div>-->

                    <button type="submit"
                            ng-disabled="submitting || !reqDescription.trim()"
                            class="w-full flex items-center justify-center gap-2 py-3 bg-green-600 hover:bg-green-700 disabled:opacity-60 text-white rounded-xl text-sm font-medium transition-all shadow-sm shadow-green-200 focus:outline-none focus:ring-2 focus:ring-green-500">
                        <lucide-icon name="send" size="14"></lucide-icon>
                        {{ submitting ? 'Submitting…' : 'Submit Request' }}
                    </button>
                </form>
            </div>

            <!-- Empty State -->
            <div ng-if="myMaintenance.length === 0" class="text-center py-8">
                <lucide-icon name="wrench" size="28" class="text-slate-200 mx-auto mb-2"></lucide-icon>
                <p class="text-slate-400 text-sm">No maintenance requests yet.</p>
                <p class="text-slate-400 text-xs mt-0.5">Submit a request above when something needs fixing.</p>
            </div>

            <!-- Maintenance List -->
            <div ng-if="myMaintenance.length > 0" class="space-y-3">
                <div ng-repeat="m in myMaintenance" class="flex items-start justify-between p-4 bg-slate-50 rounded-xl gap-3">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap mb-1">
                            <p class="text-sm text-slate-800 font-medium">{{ m.category }}</p>
                        </div>
                        <p class="text-xs text-slate-500 line-clamp-2">{{ m.description }}</p>

                        <!-- Photo indicator -->
                        <span ng-if="m.photoUrl" class="mt-1.5 inline-flex items-center gap-1 text-xs text-green-700 bg-green-50 border border-green-100 px-2 py-0.5 rounded-full">
                            <lucide-icon name="image" size="10"></lucide-icon> Photo attached
                        </span>

                        <p class="text-xs text-slate-400 mt-1.5">
                            Reported: {{ m.reportedDate }}
                            <span ng-if="m.resolvedDate"> &middot; Resolved: {{ m.resolvedDate }}</span>
                        </p>

                        <div ng-if="m.scheduledDate" class="mt-2 inline-flex items-center gap-1.5 px-2.5 py-1.5 bg-green-50 border border-green-100 rounded-lg text-xs text-green-700">
                            <lucide-icon name="calendar-clock" size="12"></lucide-icon>
                            <span>
                                Maintenance scheduled: <strong>{{ formatScheduledDate(m.scheduledDate) }}</strong>
                                <span ng-if="m.scheduledTime">
                                    at <strong>{{ m.scheduledTime }}</strong>
                                </span>
                            </span>
                        </div>
                    </div>

                    <span class="text-xs px-2.5 py-1 rounded-full font-medium flex-shrink-0"
                          ng-class="getMaintenanceStatusClass(m.status)">
                        {{ m.status }}
                    </span>
                </div>
            </div>

        </div>
    </main>
</div>