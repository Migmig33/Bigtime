@{
    Layout = "~/Views/Shared/_RentersLayout.cshtml";
}

<div class="min-h-screen bg-white" ng-init="currentPage = 'Home'">
    <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-green-950 to-slate-800 text-white" style="min-height: 560px;">

        <div class="absolute inset-0 opacity-10">
            <div class="absolute top-10 left-10 w-72 h-72 bg-green-500 rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-96 h-96 bg-emerald-600 rounded-full blur-3xl"></div>
        </div>

        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-24">
            <div class="max-w-2xl fade-in-up">
                <div class="inline-flex items-center gap-2 bg-green-600/30 text-green-300 text-sm px-3 py-1.5 rounded-full border border-green-500/30 mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" />
                        <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" />
                        <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" />
                        <path d="M10 6h4" />
                        <path d="M10 10h4" />
                        <path d="M10 14h4" />
                        <path d="M10 18h4" />
                    </svg>
                    {{ vm.availableUnits.length }} units available now
                </div>

                <h1 class="text-4xl sm:text-5xl lg:text-6xl text-white mb-6" style="line-height: 1.15;">
                    Find Your Perfect <span class="text-green-400">Home</span> in the City
                </h1>

                <p class="text-slate-300 text-lg mb-10 max-w-lg">
                    Premium rental units in Metro Manila's most sought-after locations. Fully furnished, professionally managed.
                </p>

                <form ng-submit="vm.handleSearch()" class="flex gap-3 max-w-xl">
                    <div class="relative flex-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400">
                            <circle cx="11" cy="11" r="8" />
                            <path d="m21 21-4.3-4.3" />
                        </svg>
                        <input type="text"
                               ng-model="vm.search"
                               placeholder="Search by unit name, area, or type..."
                               class="w-full pl-10 pr-4 py-3.5 rounded-xl bg-white text-slate-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-500 shadow-lg"
                               aria-label="Search units" />
                    </div>
                    <button type="submit" class="px-6 py-3.5 bg-green-600 hover:bg-green-500 text-white rounded-xl text-sm font-medium transition-all shadow-lg focus:outline-none focus:ring-2 focus:ring-green-400">
                        Search
                    </button>
                </form>

                <div class="flex flex-wrap gap-2 mt-4">
                    <button ng-repeat="tag in vm.tags"
                            ng-click="vm.browseTag(tag)"
                            class="text-xs px-3 py-1.5 bg-white/10 hover:bg-white/20 text-white rounded-full border border-white/20 transition-all focus:outline-none focus:ring-2 focus:ring-white/50">
                        {{ tag }}
                    </button>
                </div>

            </div>
        </div>

        <div class="absolute bottom-0 left-0 right-0">
            <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 80L1440 80L1440 40C1200 80 960 0 720 40C480 80 240 0 0 40L0 80Z" fill="white" />
            </svg>
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-16">
        <div class="mb-8 flex items-end justify-between">
            <div>
                <h2 class="text-slate-900 mb-1 font-bold text-2xl">Featured Units</h2>
                <p class="text-slate-500 text-sm">
                    {{ vm.availableUnits.length }} unit{{ vm.availableUnits.length !== 1 ? 's' : '' }} ready to rent
                </p>
            </div>
            <button ng-click="vm.goToBrowse()" class="flex items-center gap-1.5 text-sm text-green-600 hover:text-green-700 font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-green-500 rounded-lg px-2 py-1">
                View all
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m9 18 6-6-6-6" />
                </svg>
            </button>
        </div>

        <div ng-if="vm.featuredUnits.length === 0" class="text-center py-16 bg-slate-50 rounded-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 mx-auto mb-3">
                <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" />
                <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" />
                <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" />
                <path d="M10 6h4" />
                <path d="M10 10h4" />
                <path d="M10 14h4" />
                <path d="M10 18h4" />
            </svg>
            <p class="text-slate-500 text-sm">All units are currently occupied. Check back soon!</p>
        </div>

        <div ng-if="vm.featuredUnits.length > 0" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            <unit-card ng-repeat="unit in vm.featuredUnits"
                       unit="unit"
                       occupancy-status="vm.getOccupancy(unit.name)"
                       ng-click="vm.goToUnit(unit.id)">
            </unit-card>
        </div>

        <div class="text-center mt-4">
            <button ng-click="vm.goToBrowse()" class="inline-flex items-center gap-2 px-8 py-3.5 bg-green-600 hover:bg-green-700 text-white rounded-xl text-sm font-medium transition-all shadow-lg shadow-green-200 focus:outline-none focus:ring-2 focus:ring-green-500">
                Browse All Available Units
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                </svg>
            </button>
        </div>
    </section>

    <section class="bg-gradient-to-r from-green-600 to-green-700 py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-3xl text-white mb-3 font-semibold">Ready to Move In?</h2>
            <p class="text-green-100 mb-8 max-w-md mx-auto">
                Book a viewing today and take the first step toward your new home.
            </p>
            <button ng-click="vm.goToBrowse()" class="px-8 py-3.5 bg-white text-green-700 rounded-xl text-sm font-semibold transition-all hover:bg-green-50 focus:outline-none focus:ring-2 focus:ring-white">
                Explore Units &rarr;
            </button>
        </div>
    </section>
</div>