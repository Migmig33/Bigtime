@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="p-6 space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-slate-900 text-2xl font-bold">Bookings</h1>
            <p class="text-slate-500 text-sm">{{ bookings.length }} total viewing requests</p>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 items-start">

        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
            <button ng-click="isBusyOpen = !isBusyOpen" class="w-full flex items-center justify-between px-5 py-4 hover:bg-slate-50 transition-colors focus:outline-none">
                <div class="flex items-center gap-2.5">
                    <div class="w-8 h-8 bg-orange-100 rounded-lg flex items-center justify-center">
                        <i data-lucide="calendar-off" class="text-orange-600 w-4 h-4"></i>
                    </div>
                    <div class="text-left">
                        <p class="text-slate-900 text-sm font-semibold">Admin Busy Schedule</p>
                        <p class="text-slate-400 text-xs">Manage dates blocked from public booking</p>
                    </div>
                </div>
                <i data-lucide="chevron-right" class="text-slate-400 w-4 h-4 transition-transform" ng-class="{'rotate-90': isBusyOpen}"></i>
            </button>

            <div ng-show="isBusyOpen" class="border-t border-slate-100 p-5">
                <div class="space-y-2">
                    <div ng-repeat="date in busyDates" class="flex items-center justify-between px-3 py-2.5 bg-orange-50 border border-orange-100 rounded-xl">
                        <span class="text-sm text-orange-800 font-medium">{{ date | date:'fullDate' }}</span>
                        <button class="text-orange-400 hover:text-orange-700 focus:outline-none" ng-click="removeBusyDate(date)">
                            <i data-lucide="x" class="w-4 h-4"></i>
                        </button>
                    </div>
                    <div ng-if="busyDates.length === 0" class="text-center py-8 text-slate-400 text-sm border-2 border-dashed border-slate-200 rounded-xl">
                        No busy dates set.
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
            <button ng-click="isUpcomingOpen = !isUpcomingOpen" class="w-full flex items-center justify-between px-5 py-4 hover:bg-slate-50 transition-colors focus:outline-none">
                <div class="flex items-center gap-2.5">
                    <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
                        <i data-lucide="calendar" class="text-green-600 w-4 h-4"></i>
                    </div>
                    <div class="text-left">
                        <p class="text-slate-900 text-sm font-semibold">Upcoming Viewing Schedule</p>
                    </div>
                </div>
                <i data-lucide="chevron-right" class="text-slate-400 w-4 h-4 transition-transform" ng-class="{'rotate-90': isUpcomingOpen}"></i>
            </button>

            <div ng-show="isUpcomingOpen" class="border-t border-slate-100 p-5 space-y-5 max-h-[420px] overflow-y-auto">
                <div ng-if="(upcomingBookings | filter:true).length === 0" class="text-center py-12 border-2 border-dashed border-slate-200 rounded-xl">
                    <p class="text-slate-400 text-sm">No upcoming viewings</p>
                </div>

                <div ng-repeat="(dateKey, dayBookings) in groupedBookings">
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">{{ dateKey | date:'EEEE, MMMM d, yyyy' }}</p>
                    <div class="space-y-2 pl-4 border-l-2 border-slate-100">
                        <button ng-repeat="b in dayBookings" ng-click="openDetailModal(b)" class="w-full text-left flex items-start gap-3 px-3 py-2.5 rounded-xl border border-slate-100 hover:border-green-200 hover:bg-green-50 transition-all focus:outline-none">
                            <div class="flex-1">
                                <p class="text-sm font-medium text-slate-900">{{ b.name }}</p>
                                <p class="text-xs text-slate-400">{{ b.unitName }} • {{ b.datetime | date:'shortTime' }}</p>
                            </div>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div>
        <div class="flex gap-2 mb-4 flex-wrap">
            <button ng-repeat="tab in ['All', 'Pending', 'Confirmed', 'Declined', 'Cancelled']"
                    ng-click="setFilter(tab)"
                    ng-class="currentFilter === tab ? 'bg-green-600 text-white' : 'bg-white text-slate-600 hover:border-slate-300'"
                    class="px-4 py-2 rounded-xl text-sm font-medium border border-slate-200 transition-all focus:outline-none">
                {{ tab }}
            </button>
        </div>

        <div class="relative mb-5">
            <i data-lucide="search" class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 w-4 h-4"></i>
            <input type="text" ng-model="searchText" placeholder="Search bookings..." class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-green-500 text-sm" />
        </div>

        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-left">
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium">Guest</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium">Unit</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium">Date & Time</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium">Status</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <tr ng-repeat="b in bookings | filter:searchText | filter:statusFilter" class="hover:bg-slate-50 transition-colors">
                        <td class="px-5 py-3">
                            <p class="text-slate-900 text-sm font-medium">{{ b.name }}</p>
                            <p class="text-slate-400 text-xs">{{ b.email }}</p>
                        </td>
                        <td class="px-5 py-3 text-sm text-slate-700">{{ b.unitName }}</td>
                        <td class="px-5 py-3 text-xs text-slate-500">{{ b.datetime | date:'MMM dd, yyyy \'at\' h:mm a' }}</td>
                        <td class="px-5 py-3">
                            <span class="px-2 py-1 rounded-full text-xs font-medium"
                                  ng-class="{
                                      'bg-amber-100 text-amber-700': b.status === 'Pending',
                                      'bg-green-100 text-green-700': b.status === 'Confirmed',
                                      'bg-red-100 text-red-700': b.status === 'Declined' || b.status === 'Cancelled'
                                  }">
                                {{ b.status }}
                            </span>
                        </td>
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-1.5">
                                <button ng-click="openDetailModal(b)" class="p-1.5 rounded-lg hover:bg-green-50 text-slate-400 hover:text-green-600 focus:outline-none"><i data-lucide="eye" class="w-4 h-4"></i></button>
                                <button ng-if="b.status === 'Pending'" ng-click="updateStatus(b.id, 'Confirmed')" class="p-1.5 rounded-lg hover:bg-green-50 text-slate-400 hover:text-green-600 focus:outline-none"><i data-lucide="check" class="w-4 h-4"></i></button>
                                <button ng-if="b.status === 'Pending'" ng-click="updateStatus(b.id, 'Declined')" class="p-1.5 rounded-lg hover:bg-red-50 text-slate-400 hover:text-red-600 focus:outline-none"><i data-lucide="x" class="w-4 h-4"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr ng-if="(bookings | filter:searchText | filter:statusFilter).length === 0">
                        <td colspan="5" class="text-center py-12 text-slate-400 text-sm">No bookings found</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div ng-show="selectedBooking" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm flex items-center justify-center z-50">
        <div class="bg-white rounded-2xl w-full max-w-md p-6 shadow-xl">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-lg font-semibold text-slate-900">Booking Details</h2>
                <button ng-click="closeModal()" class="text-slate-400 hover:text-slate-700 focus:outline-none"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="space-y-4">
                <div class="flex items-center gap-3 pb-4 border-b border-slate-100">
                    <div>
                        <h3 class="text-slate-900 font-medium">{{ selectedBooking.name }}</h3>
                        <p class="text-sm text-slate-500">{{ selectedBooking.status }}</p>
                    </div>
                </div>
                <div class="text-sm space-y-2 text-slate-700">
                    <p><strong>Email:</strong> {{ selectedBooking.email }}</p>
                    <p><strong>Phone:</strong> {{ selectedBooking.phone || 'N/A' }}</p>
                    <p><strong>Unit:</strong> {{ selectedBooking.unitName }}</p>
                    <p><strong>Date & Time:</strong> {{ selectedBooking.datetime | date:'MMM dd, yyyy \'at\' h:mm a' }}</p>
                </div>
                <div class="flex gap-3 pt-4" ng-if="selectedBooking.status === 'Pending'">
                    <button ng-click="updateStatus(selectedBooking.id, 'Declined'); closeModal()" class="flex-1 py-2 rounded-xl border border-red-200 text-red-600 font-medium hover:bg-red-50 transition-all">Decline</button>
                    <button ng-click="updateStatus(selectedBooking.id, 'Confirmed'); closeModal()" class="flex-1 py-2 rounded-xl bg-green-600 text-white font-medium hover:bg-green-700 transition-all">Confirm</button>
                </div>
            </div>
        </div>
    </div>
</div>