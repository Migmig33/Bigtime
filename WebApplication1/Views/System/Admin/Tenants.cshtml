            <p class="text-slate-600 text-sm mb-5">Are you sure you want to remove <strong>{{ deleteTarget.name }}</strong>? This cannot be undone.</p>
            <div class="flex gap-3">
                <button ng-click="closeModals()" class="flex-1 py-2.5 rounded-xl border border-slate-200 text-slate-700 text-sm hover:bg-slate-50 transition-all">Cancel</button>
                <button ng-click="confirmDelete()" class="flex-1 py-2.5 rounded-xl bg-red-600 hover:bg-red-700 text-white text-sm transition-all">Remove</button>
            </div>
        </div>
    </div>*@
</div>

