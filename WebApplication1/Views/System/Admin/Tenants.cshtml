        <div class="bg-white rounded-2xl w-full max-w-sm p-6 shadow-xl relative">
            <div class="flex justify-center mb-4">
                <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center">
                    <i data-lucide="alert-triangle" class="text-orange-500 w-8 h-8"></i>
                </div>
            </div>
            <h3 class="text-lg font-semibold text-center mb-2">Terminate Account</h3>
            <div class="bg-orange-50 border border-orange-100 rounded-xl p-4 mb-5 space-y-2">
                <p class="text-orange-800 text-xs font-semibold flex items-center gap-1.5">
                    <i data-lucide="shield-off" class="w-3 h-3"></i> What will happen to {{ terminateTarget.name }}:
                </p>
                <ul class="space-y-1.5 text-xs text-orange-700 list-disc list-inside">
