@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<!-- Toast Notification -->
<div ng-show="toastShow"
     style="animation: slideDown 0.5s ease-in-out"
     class="fixed top-4 right-4 z-[100] flex items-center gap-3 bg-white border border-slate-200 shadow-sm rounded-2xl px-5 py-4 w-[400px] max-w-full transition-all duration-300">

    <!-- Icon -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-gray-900 shrink-0">
        <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 8a.75.75 0 00-1.5 0v4a.75.75 0 001.5 0V8zM12 16a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
    </svg>

    <!-- Dynamic Message -->
    <span class="text-slate-800 font-medium text-[15px]">{{ toast.message }}</span>
</div>
<div class="p-6 flex flex-col min-w-0 overflow-hidden" ng-init="currentPage = 'Tenant'; getAllTenants();  getAllUnits();">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-slate-900 text-2xl font-bold">Tenants</h1>
            <p class="text-slate-500 text-sm">{{ tenants.length }} registered tenants</p>
        </div>
        <button ng-click="triggerAddTenant()" class="flex items-center gap-2 px-4 py-2.5 bg-green-600 hover:bg-green-700 text-white rounded-xl text-sm font-medium transition-all focus:outline-none focus:ring-2 focus:ring-green-500">
            <i data-lucide="plus" class="w-4 h-4"></i> Add Tenant
        </button>
    </div>

    <!-- Search + Sort -->
    <div class="flex gap-2 mb-3">
        <div class="relative flex-1 min-w-0">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input type="text" ng-model="tenantSearchQuery" placeholder="Search by name, email, unit..."
                   class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
        </div>
        <button ng-click="toggleTenantSort()"
                class="flex items-center gap-1.5 px-3 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-600 hover:border-green-300 hover:text-green-700 text-sm font-medium transition-all whitespace-nowrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 6h18M7 12h10M11 18h2" />
            </svg>
            <span class="hidden sm:inline">{{ tenantSortAsc ? 'A → Z' : 'Z → A' }}</span>
        </button>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-y-2 gap-x-4 mb-3 p-3 bg-slate-50 border border-slate-100 rounded-2xl">

        <!-- Contract Type -->
        <div class="flex items-center gap-2 flex-wrap">
            <span class="text-xs text-slate-400 font-medium">Contract:</span>
            <button ng-click="setTenantContract('All')"
                    ng-class="tenantContractFilter === 'All' ? 'bg-green-600 text-white border-green-600' : 'bg-white text-slate-600 border-slate-200'"
                    class="px-3 py-1 rounded-lg text-xs font-medium border transition-all">
                All
            </button>
            <button ng-click="setTenantContract('Short-term')"
                    ng-class="tenantContractFilter === 'Short-term' ? 'bg-purple-600 text-white border-purple-600' : 'bg-white text-slate-600 border-slate-200'"
                    class="px-3 py-1 rounded-lg text-xs font-medium border transition-all">
                Short-term
            </button>
            <button ng-click="setTenantContract('Mid-term')"
                    ng-class="tenantContractFilter === 'Mid-term' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-slate-600 border-slate-200'"
                    class="px-3 py-1 rounded-lg text-xs font-medium border transition-all">
                Mid-term
            </button>
            <button ng-click="setTenantContract('Long-term')"
                    ng-class="tenantContractFilter === 'Long-term' ? 'bg-indigo-600 text-white border-indigo-600' : 'bg-white text-slate-600 border-slate-200'"
                    class="px-3 py-1 rounded-lg text-xs font-medium border transition-all">
                Long-term
            </button>
        </div>

        <div class="hidden sm:block w-px bg-slate-200 self-stretch"></div>

        <!-- Status -->
        <div class="flex items-center gap-2 flex-wrap">
            <span class="text-xs text-slate-400 font-medium">Status:</span>
            <button ng-click="setTenantLiveStatus('All')"
                    ng-class="tenantLiveStatusFilter === 'All' ? 'bg-green-600 text-white border-green-600' : 'bg-white text-slate-600 border-slate-200'"
                    class="px-3 py-1 rounded-lg text-xs font-medium border transition-all">
                All
            </button>
            <button ng-click="setTenantLiveStatus('Active')"
                    ng-class="tenantLiveStatusFilter === 'Active' ? 'bg-emerald-600 text-white border-emerald-600' : 'bg-white text-slate-600 border-slate-200'"
                    class="px-3 py-1 rounded-lg text-xs font-medium border transition-all">
                Active
            </button>
            <button ng-click="setTenantLiveStatus('Expiring')"
                    ng-class="tenantLiveStatusFilter === 'Expiring' ? 'bg-amber-500 text-white border-amber-500' : 'bg-white text-slate-600 border-slate-200'"
                    class="px-3 py-1 rounded-lg text-xs font-medium border transition-all">
                Expiring
            </button>
            <button ng-click="setTenantLiveStatus('Expired')"
                    ng-class="tenantLiveStatusFilter === 'Expired' ? 'bg-red-600 text-white border-red-600' : 'bg-white text-slate-600 border-slate-200'"
                    class="px-3 py-1 rounded-lg text-xs font-medium border transition-all">
                Expired
            </button>
            <button ng-click="setTenantLiveStatus('Terminated')"
                    ng-class="tenantLiveStatusFilter === 'Terminated' ? 'bg-slate-600 text-white border-slate-600' : 'bg-white text-slate-600 border-slate-200'"
                    class="px-3 py-1 rounded-lg text-xs font-medium border transition-all">
                Terminated
            </button>
        </div>

        <!-- Reset -->
        <button ng-if="tenantContractFilter !== 'All' || tenantLiveStatusFilter !== 'All'"
                ng-click="tenantContractFilter = 'All'; tenantLiveStatusFilter = 'All'"
                class="ml-auto text-xs text-slate-400 hover:text-red-500 flex items-center gap-1 transition-colors">
            <i data-lucide="x" class="w-3 h-3"></i> Reset
        </button>

    </div>

    <!-- Result count -->
    <p ng-if="tenantContractFilter !== 'All' || tenantLiveStatusFilter !== 'All' || tenantSearchQuery"
       class="text-xs text-slate-400 mb-3">
        Showing <span class="text-slate-700 font-medium">{{ filteredTenants().length }}</span> of {{ tenants.length }} tenants
    </p>

    <!-- Table Card -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden min-w-0">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Tenant ID</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Tenant</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Unit</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Occupancy</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Lease Period</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Days Left</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Contract</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Status</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Payment</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">IDs</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <tr ng-repeat="t in filteredTenants()" ng-class="{'opacity-60': t.isTerminated}" class="hover:bg-slate-50 transition-colors">

                        <td class="px-5 py-3 whitespace-nowrap">
                            <span ng-if="t.tenantNumber" class="inline-flex items-center gap-1 px-2.5 py-1 bg-green-50 text-green-700 border border-green-100 rounded-lg text-xs font-mono font-semibold tracking-wide">
                                <i data-lucide="hash" class="w-3 h-3 text-green-500"></i>{{ t.tenantNumber }}
                            </span>
                            <span ng-if="!t.tenantNumber" class="text-slate-300 text-xs">—</span>
                        </td>

                        <td class="px-5 py-3">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-semibold flex-shrink-0"
                                     ng-class="t.isTerminated ? 'bg-red-100 text-red-400' : 'bg-green-100 text-green-700'">
                                    {{ t.name.charAt(0) }}
                                </div>
                                <div>
                                    <div class="flex items-center gap-1.5">
                                        <p class="text-slate-900 text-sm font-medium">{{ t.name }}</p>
                                        <span ng-if="t.isTerminated" class="inline-flex items-center gap-0.5 px-1.5 py-0.5 bg-red-100 text-red-600 text-xs rounded-full font-medium whitespace-nowrap">
                                            <i data-lucide="shield-off" class="w-2.5 h-2.5"></i> Terminated
                                        </span>
                                    </div>
                                    <p class="text-slate-400 text-xs">{{ t.email }}</p>
                                </div>
                            </div>
                        </td>

                        <td class="px-5 py-3 text-sm text-slate-600 whitespace-nowrap">{{ t.unit }}</td>

                        <td class="px-5 py-3 whitespace-nowrap">
                            <span ng-if="t.occupancyType === 'with_others'" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs border font-medium bg-green-50 text-green-700 border-green-100">
                                <i data-lucide="users" class="w-3 h-3"></i>+{{ t.additionalOccupantsCount }} co-occupant{{ t.additionalOccupantsCount !== 1 ? 's' : '' }}
                            </span>
                            <span ng-if="t.occupancyType !== 'with_others'" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs border font-medium bg-slate-50 text-slate-500 border-slate-200">
                                <i data-lucide="user" class="w-3 h-3"></i>Solo
                            </span>
                        </td>

                        <td class="px-5 py-3 text-xs text-slate-500 whitespace-nowrap">{{ t.leaseStart }} &rarr; {{ t.leaseEnd }}</td>

                        <td class="px-5 py-3 whitespace-nowrap">
                            <span ng-if="t.daysLeft !== null" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs border font-medium" ng-class="getDaysLeftClass(t.daysLeft)">
                                <i data-lucide="clock" class="w-3 h-3"></i>{{ t.daysLeft < 0 ? (t.daysLeft * -1) + 'd ago' : t.daysLeft + 'd left' }}
                            </span>
                            <span ng-if="t.daysLeft === null" class="text-slate-400 text-xs">—</span>
                        </td>

                        <td class="px-5 py-3 whitespace-nowrap">
                            <span ng-if="t.contractType" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs border font-medium" ng-class="getContractClass(t.contractType)">
                                <i data-lucide="clock" class="w-2.5 h-2.5"></i>{{ t.contractType }}
                            </span>
                            <span ng-if="!t.contractType" class="text-slate-300 text-xs">—</span>
                        </td>

                        <td class="px-5 py-3 whitespace-nowrap">
                            <span class="px-2 py-1 rounded-full text-xs font-medium" ng-class="getStatusClass(t.liveStatus)">
                                {{ t.liveStatus }}
                            </span>
                        </td>

                        <td class="px-5 py-3 whitespace-nowrap">
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs border font-medium" ng-class="getPaymentClass(t.latestPaymentStatus)">
                                <i data-lucide="credit-card" class="w-2.5 h-2.5"></i>{{ t.latestPaymentStatus === 'None' ? 'No Record' : t.latestPaymentStatus }}
                            </span>
                        </td>

                        <td class="px-5 py-3 whitespace-nowrap">
                            <span class="text-xs px-2 py-0.5 rounded-full" ng-class="t.idFilesCount > 0 ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-50 text-slate-400'">
                                {{ t.idFilesCount }} ID{{ t.idFilesCount !== 1 ? 's' : '' }}
                            </span>
                        </td>

                       
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-2">
                                <button ng-click="triggerEditTenant(t)" class="p-1.5 rounded-lg hover:bg-green-50 text-slate-400 hover:text-green-600 transition-all">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </button>
                                <button ng-click="triggerConfirmDeleteTenant(t.Tid)" class="p-1.5 rounded-lg hover:bg-red-50 text-slate-400 hover:text-red-600 transition-all">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                        <path d="M10 11v6" />
                                        <path d="M14 11v6" />
                                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                 

                <tr ng-if="filteredTenants().length === 0">
                    <td colspan="11" class="text-center py-12 text-slate-400 text-sm">No tenants found matching your criteria.</td>
                </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
<!--Tenant Editor Modal-->
<div ng-show="editorModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl max-h-[90vh] flex flex-col">

        <!-- Header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <h2 class="text-slate-900 font-semibold text-base">{{ editingTenant ? 'Edit ' + editingTenant.name : 'Add New Tenant' }}</h2>
            <button ng-click="editorModal = false" class="p-1.5 rounded-lg hover:bg-slate-100 text-slate-400 hover:text-slate-600 transition-all">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
            </button>
        </div>

        <!-- Body -->
        <div class="overflow-y-auto flex-1 p-6 space-y-5">

            <!-- Tenant ID -->
            <div class="flex items-center gap-3 p-3 bg-green-50 border border-green-100 rounded-xl">
                <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                    <i data-lucide="hash" class="w-4 h-4 text-green-600"></i>
                </div>
                <div class="flex-1">
                    <p class="text-xs text-green-600 font-medium">Tenant ID</p>
                    <p class="text-sm text-green-800 font-mono font-bold tracking-wide">{{ tenantNumber || 'Auto-generated on save' }}</p>
                </div>
                <span class="text-xs text-green-500 bg-green-100 px-2 py-0.5 rounded-full">Auto-assigned</span>
            </div>

            <!-- Occupancy Type -->
            <div>
                <label class="block text-sm text-slate-700 font-medium mb-2">Occupancy Type *</label>
                <div class="grid grid-cols-2 gap-3">
                    <!-- 1 for Solo -->
                    <button type="button" ng-click="occupancyTypeId = 1"
                            ng-class="occupancyTypeId === 1 ? 'border-green-500 bg-green-50' : 'border-slate-200 bg-white hover:border-slate-300'"
                            class="flex items-start gap-3 p-4 rounded-xl border-2 text-left transition-all">
                        <div ng-class="occupancyTypeId === 1 ? 'bg-green-100' : 'bg-slate-100'"
                             class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0">
                            <i data-lucide="user" class="w-4 h-4" ng-class="occupancyTypeId === 1 ? 'text-green-600' : 'text-slate-400'"></i>
                        </div>
                        <div>
                            <p class="text-sm font-semibold" ng-class="occupancyTypeId === 1 ? 'text-green-800' : 'text-slate-700'">Solo</p>
                            <p class="text-xs text-slate-400 mt-0.5">Only the primary tenant occupies the unit</p>
                        </div>
                    </button>
                    <!-- 2 for With Others -->
                    <button type="button" ng-click="occupancyTypeId = 2"
                            ng-class="occupancyTypeId === 2 ? 'border-blue-500 bg-blue-50' : 'border-slate-200 bg-white hover:border-slate-300'"
                            class="flex items-start gap-3 p-4 rounded-xl border-2 text-left transition-all">
                        <div ng-class="occupancyTypeId === 2 ? 'bg-blue-100' : 'bg-slate-100'"
                             class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0">
                            <i data-lucide="users" class="w-4 h-4" ng-class="occupancyTypeId === 2 ? 'text-blue-600' : 'text-slate-400'"></i>
                        </div>
                        <div>
                            <p class="text-sm font-semibold" ng-class="occupancyTypeId === 2 ? 'text-blue-800' : 'text-slate-700'">With Additional Tenants</p>
                            <p class="text-xs text-slate-400 mt-0.5">Primary tenant + co-occupants share the unit</p>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Basic Fields -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Full Name *</label>
                    <input type="text" id="fieldName" ng-model="name" placeholder="Full name"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Email *</label>
                    <input type="text" id="fieldEmail" ng-model="email" placeholder="email@example.com"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Phone</label>
                    <input type="tel" id="fieldPhone" ng-model="phone" placeholder="09XX-XXX-XXXX"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Assigned Unit</label>

                    <!-- Use ng-options for better binding and type handling -->
                    <select id="fieldUnitId"
                            ng-model="unitId"
                            ng-change="onUnitChange()"
                            ng-options="u.Uid as (u.unitName + ' (Available)') for u in units | filter:shouldShowUnit"
                            class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
                        <option value="">Select an available unit</option>
                    </select>

                    <p ng-if="unitId" class="text-xs text-amber-600 mt-1 flex items-center gap-1">
                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 inline-block"></span>
                        This unit will be marked as <strong>occupied</strong> upon saving.
                    </p>

                    <!-- Message if no units are available -->
                    <p ng-if="(units | filter:shouldShowUnit).length === 0" class="text-xs text-red-500 mt-1 flex items-center gap-1">
                        <i data-lucide="alert-circle" class="w-3 h-3"></i> No vacant units available.
                    </p>
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Lease Start</label>
                    <input type="date" id="fieldLeaseStart" ng-model="leaseStart"
                           ng-change="updateMinLeaseEnd()"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                </div>

                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Lease End</label>
                    <!-- Use ng-min for better compatibility with the Date object -->
                    <input type="date" id="fieldLeaseEnd" ng-model="leaseEnd"
                           min="{{ minLeaseEnd }}"
                           ng-disabled="!leaseStart"
                           ng-class="!leaseStart ? 'opacity-50 cursor-not-allowed' : ''"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />

                    <p ng-if="!leaseStart" class="text-xs text-slate-400 mt-1 flex items-center gap-1">
                        <i data-lucide="clock" class="w-3 h-3"></i> Set a lease start date first
                    </p>
                    <p ng-if="leaseStart" class="text-xs text-blue-500 mt-1 flex items-center gap-1">
                        <i data-lucide="info" class="w-3 h-3"></i> Minimum 3-month contract required
                    </p>
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Address</label>
                    <input type="text" id="fieldAddress" ng-model="address" placeholder="City, Province"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Occupation</label>
                    <input type="text" id="fieldOccupation" ng-model="occupation" placeholder="e.g. Engineer"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Portal Password</label>
                    <input type="text" id="fieldPasswordHash" ng-model="passwordHash" placeholder="Tenant login password"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                    <p class="text-slate-400 text-xs mt-1">Default: <span class="font-mono">123</span></p>
                </div>
            </div>

            <!-- Additional Occupants -->
            <div ng-show="occupancyTypeId === 2" class="border border-blue-100 bg-blue-50/50 rounded-2xl p-4 space-y-4">

                <!-- HEADER -->
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <i data-lucide="users" class="w-4 h-4 text-blue-600"></i>
                        <p class="text-sm text-blue-800 font-semibold">Additional Occupants</p>

                        <!-- Dynamic Max Counter -->
                        <span class="text-xs px-2 py-0.5 rounded-full transition-colors"
                              ng-class="{'bg-red-100 text-red-600': co_occupants.length >= maxCoOccupantsLimit, 'bg-blue-100 text-blue-500': co_occupants.length < maxCoOccupantsLimit}">
                            {{ co_occupants.length || 0 }} / {{ maxCoOccupantsLimit || 0 }} added
                        </span>
                    </div>

                    <!-- Add Button (Disables when limit is reached) -->
                    <button type="button"
                            ng-click="addCoOccupant()"
                            ng-disabled="co_occupants.length >= maxCoOccupantsLimit"
                            class="flex items-center gap-1.5 text-xs px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-all disabled:opacity-50 disabled:cursor-not-allowed">
                        <i data-lucide="user-plus" class="w-3 h-3"></i> Add Occupant
                    </button>
                </div>

                <!-- THE FORMS (Notice the 'track by $index' here!) -->
                <div ng-repeat="occ in co_occupants track by $index" class="bg-white border border-blue-100 rounded-xl p-4 space-y-3">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xs text-blue-600 font-semibold flex items-center gap-1.5">
                            <div class="w-5 h-5 bg-blue-100 rounded-full flex items-center justify-center text-blue-700 text-xs font-bold">{{ $index + 1 }}</div>
                            Co-occupant #{{ $index + 1 }}
                        </span>
                        <button type="button" ng-click="removeCoOccupant($index)"
                                class="p-1 rounded-lg hover:bg-red-50 text-slate-400 hover:text-red-500 transition-all">
                            <i data-lucide="trash" class="w-3.5 h-3.5"></i>
                        </button>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                        <div>
                            <label class="block text-xs text-slate-600 font-medium mb-1">Full Name *</label>
                            <input type="text" ng-model="occ.name" placeholder="Full name"
                                   class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                        </div>
                        <div>
                            <label class="block text-xs text-slate-600 font-medium mb-1">Phone *</label>
                            <input type="tel" ng-model="occ.phone" placeholder="09XX-XXX-XXXX"
                                   class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                        </div>
                        <div>
                            <label class="block text-xs text-slate-600 font-medium mb-1">Address</label>
                            <input type="text" ng-model="occ.address" placeholder="City, Province"
                                   class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                        </div>
                    </div>
                </div>

                <!-- EMPTY STATE -->
                <div ng-if="!co_occupants || co_occupants.length === 0" class="text-center py-4 text-blue-400 text-sm">
                    <i data-lucide="users" class="w-6 h-6 mx-auto mb-1 opacity-50"></i>
                    <p>No co-occupants added yet.</p>
                    <p class="text-xs mt-0.5" ng-if="maxCoOccupantsLimit > 0">Click "Add Occupant" to add up to {{ maxCoOccupantsLimit }}.</p>
                </div>
            </div>

            <!-- ID Upload -->
            <div>
                <label class="block text-sm text-slate-700 font-medium mb-2">
                    ID Documents (max 2)
                </label>

                <div class="flex gap-3 flex-wrap">

                    <!-- 1. The ID Previews -->
                    <div ng-repeat="file in idFiles track by $index"
                         class="relative w-28 h-20 rounded-xl overflow-hidden border border-slate-200 group transition-all duration-300">

                        <img ng-src="{{ file.url }}" alt="ID Document {{$index + 1}}" class="w-full h-full object-cover" />

                        <!-- The Hover "X" Button -->
                        <button type="button" ng-click="removeIdFile($index)"
                                class="absolute top-1 right-1 p-1 bg-red-500 text-white rounded-full opacity-0 group-hover:opacity-100 transition-opacity shadow-sm">
                            <!-- Pure SVG matching your reference -->
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                        </button>
                    </div>

                    <!-- 2. The Upload ID Button -->
                    <!-- Added !idFiles fallback just in case the array hasn't initialized yet -->
                    <label for="idFileInput" ng-show="!idFiles || idFiles.length < 2"
                           class="w-28 h-20 rounded-xl border-2 border-dashed border-slate-200 hover:border-green-300 flex flex-col items-center justify-center gap-1 text-slate-400 hover:text-green-500 transition-all cursor-pointer">
                        <!-- Pure SVG for File/Upload icon -->
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                        <span class="text-xs">Upload ID</span>
                    </label>

                </div>

                <!-- 3. The Hidden File Input -->
                <input type="file" id="idFileInput" accept="image/*,.pdf" multiple class="hidden"
                       onchange="angular.element(this).scope().handleIdUpload(this.files)" />
                <p class="text-slate-400 text-xs mt-1">Accepts images and PDF. Max 2 files.</p>
            </div>

        </div>

        <!-- Footer -->
        <div class="flex gap-3 justify-end px-6 py-4 border-t border-slate-100">
            <button ng-click="editorModal = false" class="px-4 py-2 rounded-xl text-sm text-slate-600 hover:bg-slate-100 border border-slate-200 transition-all">Cancel</button>
            <button ng-click="saveTenant(selectedTenant)" class="px-5 py-2 bg-green-600 hover:bg-green-700 text-white rounded-xl text-sm font-medium transition-all">
                {{ editingTenant ? 'Save Changes' : 'Add Tenant' }}
            </button>
        </div>
    </div>
</div>
<div ng-show="deleteTenantConfirm" class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm mx-4 p-6">
        <h3 class="text-slate-900 font-semibold text-base mb-2">Remove Tenant</h3>
        <p class="text-slate-600 text-sm mb-5">
            Are you sure you want to remove Tenant Id <strong>{{ selectedTenant }}</strong>? This cannot be undone.
        </p>
        <div class="flex gap-3">
            <button ng-click="deleteTenantConfirm = false" class="flex-1 py-2.5 rounded-xl border border-slate-200 text-slate-700 text-sm hover:bg-slate-50 transition-all">Cancel</button>
            <button ng-click="deleteTenant(selectedTenant)" class="flex-1 py-2.5 rounded-xl bg-red-600 text-white text-sm hover:bg-red-700 transition-all">Remove</button>
        </div>
    </div>
</div>