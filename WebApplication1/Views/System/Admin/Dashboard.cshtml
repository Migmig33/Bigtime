@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<div class="p-6 space-y-6 overflow-y-auto flex-1">

    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-slate-900 text-2xl font-bold">Dashboard</h1>
            <p class="text-slate-500 text-sm">Overview of GreenResidences operations</p>
        </div>
        <div class="text-slate-400 text-sm">May 2026</div>
    </div>
     
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

        <button ng-click="goTo('Units')" class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm hover:shadow-md transition-all text-left">
            <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" /><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" /><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" /></svg>
                </div>
                <span class="flex items-center gap-0.5 text-xs text-emerald-600 font-medium">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>
                    +2 this month
                </span>
            </div>
            <p class="text-slate-500 text-xs mb-1">Active Units</p>
            <p class="text-slate-900 text-2xl font-bold">12</p>
            <p class="text-slate-400 text-xs mt-1">3 vacant</p>
        </button>

        <button ng-click="goTo('Bookings')" class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm hover:shadow-md transition-all text-left">
            <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                </div>
            </div>
            <p class="text-slate-500 text-xs mb-1">Pending Bookings</p>
            <p class="text-slate-900 text-2xl font-bold">5</p>
            <p class="text-slate-400 text-xs mt-1">Awaiting review</p>
        </button>

        <button ng-click="goTo('Payments')" class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm hover:shadow-md transition-all text-left">
            <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" /><line x1="1" y1="10" x2="23" y2="10" /></svg>
                </div>
                <span class="flex items-center gap-0.5 text-xs text-emerald-600 font-medium">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg>
                    +12%
                </span>
            </div>
            <p class="text-slate-500 text-xs mb-1">Revenue (Apr)</p>
            <p class="text-slate-900 text-2xl font-bold">₱85,000</p>
            <p class="text-slate-400 text-xs mt-1">2 overdue</p>
        </button>

        <button ng-click="goTo('Maintenance')" class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm hover:shadow-md transition-all text-left">
            <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>
                </div>
            </div>
            <p class="text-slate-500 text-xs mb-1">Open Maintenance</p>
            <p class="text-slate-900 text-2xl font-bold">4</p>
            <p class="text-slate-400 text-xs mt-1">Requests pending</p>
        </button>

    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <div class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm">
            <h3 class="text-slate-900 font-semibold mb-4">Monthly Revenue</h3>
            <canvas id="revenueChart" height="200"></canvas>
        </div>

        <div class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm">
            <h3 class="text-slate-900 font-semibold mb-4">Occupancy Trend</h3>
            <canvas id="occupancyChart" height="200"></canvas>
        </div>

    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
            <h3 class="text-slate-900 font-semibold">Recent Bookings</h3>
            <button ng-click="goTo('Bookings')" class="text-green-600 text-xs flex items-center gap-1 hover:text-green-700 transition-colors">
                View all
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7" /><polyline points="7 7 17 7 17 17" /></svg>
            </button>
        </div>
        <div class="divide-y divide-slate-50">

            <div class="flex items-center gap-4 px-5 py-3">
                <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-semibold flex-shrink-0">J</div>
                <div class="flex-1 min-w-0">
                    <p class="text-slate-900 text-sm font-medium truncate">Juan Dela Cruz</p>
                    <p class="text-slate-400 text-xs">Unit 3B · Apr 25</p>
                </div>
                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-amber-50 text-amber-600">Pending</span>
            </div>

            <div class="flex items-center gap-4 px-5 py-3">
                <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-semibold flex-shrink-0">M</div>
                <div class="flex-1 min-w-0">
                    <p class="text-slate-900 text-sm font-medium truncate">Maria Santos</p>
                    <p class="text-slate-400 text-xs">Unit 1A · Apr 23</p>
                </div>
                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-green-50 text-green-600">Approved</span>
            </div>

            <div class="flex items-center gap-4 px-5 py-3">
                <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-semibold flex-shrink-0">R</div>
                <div class="flex-1 min-w-0">
                    <p class="text-slate-900 text-sm font-medium truncate">Ramon Reyes</p>
                    <p class="text-slate-400 text-xs">Unit 2C · Apr 21</p>
                </div>
                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-red-50 text-red-500">Rejected</span>
            </div>

            <div class="flex items-center gap-4 px-5 py-3">
                <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-semibold flex-shrink-0">A</div>
                <div class="flex-1 min-w-0">
                    <p class="text-slate-900 text-sm font-medium truncate">Ana Gonzales</p>
                    <p class="text-slate-400 text-xs">Unit 4D · Apr 20</p>
                </div>
                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-amber-50 text-amber-600">Pending</span>
            </div>

            <div class="flex items-center gap-4 px-5 py-3">
                <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-xs font-semibold flex-shrink-0">C</div>
                <div class="flex-1 min-w-0">
                    <p class="text-slate-900 text-sm font-medium truncate">Carlos Mendoza</p>
                    <p class="text-slate-400 text-xs">Unit 2A · Apr 18</p>
                </div>
                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-green-50 text-green-600">Approved</span>
            </div>

        </div>
    </div>

</div>