@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-6" ng-init="getAllPayments(); currentPage = 'Payments'">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-slate-900 text-2xl font-bold">Payments</h1>
            <p class="text-slate-500 text-sm">{{ payments.length }} payment records</p>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <!-- Paid -->
        <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-4">
            <div class="flex items-center gap-2 mb-2">
                <i data-lucide="check-circle" class="w-4 h-4 text-emerald-600"></i>
                <span class="text-emerald-700 text-sm font-medium">Paid</span>
            </div>
            <p class="text-2xl font-bold text-emerald-800">₱{{ totalPaid | number:0 }}</p>
            <p class="text-emerald-600 text-xs mt-1">{{ countByPaymentStatus('Paid') }} payments</p>
        </div>
        <!-- Overdue -->
        <div class="bg-red-50 border border-red-100 rounded-2xl p-4">
            <div class="flex items-center gap-2 mb-2">
                <i data-lucide="alert-triangle" class="w-4 h-4 text-red-600"></i>
                <span class="text-red-700 text-sm font-medium">Overdue</span>
            </div>
            <p class="text-2xl font-bold text-red-800">₱{{ totalOverdue | number:0 }}</p>
            <p class="text-red-600 text-xs mt-1">{{ countByPaymentStatus('Overdue') }} payments</p>
        </div>
        <!-- Unpaid -->
        <div class="bg-amber-50 border border-amber-100 rounded-2xl p-4">
            <div class="flex items-center gap-2 mb-2">
                <i data-lucide="credit-card" class="w-4 h-4 text-amber-600"></i>
                <span class="text-amber-700 text-sm font-medium">Unpaid</span>
            </div>
            <p class="text-2xl font-bold text-amber-800">₱{{ totalUnpaid | number:0 }}</p>
            <p class="text-amber-600 text-xs mt-1">{{ countByPaymentStatus('Unpaid') }} payments</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="flex gap-2 mb-4 flex-wrap">
        <button ng-click=""
                ng-class="paymentFilter === 'All' ? 'bg-green-600 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:border-slate-300'"
                class="px-4 py-2 rounded-xl text-sm font-medium transition-all">
            All
        </button>
        <button ng-click=""
                ng-class="paymentFilter === 'Paid' ? 'bg-green-600 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:border-slate-300'"
                class="px-4 py-2 rounded-xl text-sm font-medium transition-all">
            Paid
        </button>
        <button ng-click=""
                ng-class="paymentFilter === 'Overdue' ? 'bg-green-600 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:border-slate-300'"
                class="px-4 py-2 rounded-xl text-sm font-medium transition-all">
            Overdue
        </button>
        <button ng-click=""
                ng-class="paymentFilter === 'Unpaid' ? 'bg-green-600 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:border-slate-300'"
                class="px-4 py-2 rounded-xl text-sm font-medium transition-all">
            Unpaid
        </button>
    </div>

    <!-- Search -->
    <div class="relative mb-5">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input type="text" ng-model="paymentSearch" placeholder="Search payments..."
               class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-left">
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Tenant</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Unit</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Period</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Amount</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Due Date</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Status</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium whitespace-nowrap">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <tr ng-repeat="p in filteredPayments()"
                        class="hover:bg-slate-50 transition-colors"
                        ng-class="{'bg-red-50/30': p.status === 'Overdue'}">

                        <!-- Tenant -->
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-2">
                                <div class="w-7 h-7 bg-green-100 rounded-full flex items-center justify-center text-green-700 text-xs font-semibold flex-shrink-0">
                                    {{ p.tenantName.charAt(0) }}
                                </div>
                                <span class="text-slate-900 text-sm whitespace-nowrap">{{ p.tenantName }}</span>
                            </div>
                        </td>

                        <!-- Unit -->
                        <td class="px-5 py-3 text-sm text-slate-600 whitespace-nowrap">{{ p.unitName }}</td>

                        <!-- Period -->
                        <td class="px-5 py-3 text-sm text-slate-600 whitespace-nowrap">{{ p.month }}</td>

                        <!-- Amount -->
                        <td class="px-5 py-3 text-sm text-slate-900 font-semibold whitespace-nowrap">₱{{ p.amount | number:0 }}</td>

                        <!-- Due Date -->
                        <td class="px-5 py-3 text-xs text-slate-500 whitespace-nowrap">
                            {{ p.dueDate }}
                            <span ng-if="p.paidDate" class="block text-emerald-600">Paid: {{ p.paidDate }}</span>
                        </td>

                        <!-- Status -->
                        <td class="px-5 py-3 whitespace-nowrap">
                            <span class="px-2 py-1 rounded-full text-xs font-medium"
                                  ng-class="{
                                    'bg-emerald-50 text-emerald-700': p.status === 'Paid',
                                    'bg-red-50 text-red-600': p.status === 'Overdue',
                                    'bg-amber-50 text-amber-700': p.status === 'Unpaid'
                                  }">
                                {{ p.status }}
                            </span>
                        </td>

                        <!-- Action -->
                        <td class="px-5 py-3 whitespace-nowrap">
                            <button ng-if="p.status === 'Overdue' || p.status === 'Unpaid'"
                                    ng-click=""
                                    class="flex items-center gap-1.5 text-xs px-3 py-1.5 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 rounded-lg transition-all">
                                <i data-lucide="calendar-check" class="w-3 h-3"></i>
                                Mark Paid
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- Empty State -->
            <div ng-if="filteredPayments().length === 0"
                 class="text-center py-12 text-slate-400 text-sm">
                No payments found
            </div>
        </div>
    </div>

</div>

<!-- ── Mark Paid Modal ── -->
<div ng-show="markPaidTarget" class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md flex flex-col max-h-[90vh]">

        <!-- Header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <h2 class="text-slate-900 font-semibold text-base">Mark Payment as Paid</h2>
            <button ng-click="" class="p-1.5 rounded-lg hover:bg-slate-100 text-slate-400 hover:text-slate-600 transition-all">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>

        <!-- Body -->
        <div class="overflow-y-auto flex-1 p-6 space-y-5">

            <!-- Tenant Summary -->
            <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-green-700 font-bold text-base flex-shrink-0">
                    {{ markPaidTarget.tenantName.charAt(0) }}
                </div>
                <div>
                    <p class="text-slate-900 text-sm font-medium">{{ markPaidTarget.tenantName }}</p>
                    <p class="text-slate-500 text-xs">{{ markPaidTarget.unitName }} · ₱{{ markPaidTarget.amount | number:0 }}/mo</p>
                </div>
                <div class="ml-auto text-right">
                    <p class="text-xs text-slate-400">Starting from</p>
                    <p class="text-sm font-semibold text-slate-800">{{ markPaidTarget.month }}</p>
                </div>
            </div>

            <!-- Paid Until Selector -->
            <div>
                <p class="text-sm text-slate-700 font-medium mb-1">Paid until:</p>
                <p class="text-xs text-slate-400 mb-3">
                    All months from <strong>{{ markPaidTarget.month }}</strong> through the selected month will be marked as
                    <span class="text-emerald-600 font-medium">Paid</span>.
                </p>

                <div class="grid grid-cols-3 sm:grid-cols-4 gap-2">
                    <button ng-repeat="opt in monthOptions"
                            type="button"
                            ng-click=""
                            ng-class="{
                                'bg-green-600 text-white border-green-600 shadow-md': paidUntil === opt.key,
                                'bg-green-50 text-green-700 border-green-200': isInRange(opt) && paidUntil !== opt.key,
                                'bg-white text-slate-600 border-slate-200 hover:border-green-300': !isInRange(opt) && paidUntil !== opt.key
                            }"
                            class="relative px-2 py-3 rounded-xl text-xs font-medium border transition-all">
                        <span class="block">{{ opt.shortMonth }}</span>
                        <span class="block text-xs" ng-class="paidUntil === opt.key ? 'text-green-200' : 'text-slate-400'">{{ opt.year }}</span>
                    </button>
                </div>
            </div>

            <!-- Preview -->
            <div ng-if="paidUntil" class="bg-emerald-50 border border-emerald-100 rounded-xl p-4">
                <p class="text-xs text-emerald-700 font-semibold mb-2 flex items-center gap-1.5">
                    <i data-lucide="check-circle" class="w-3 h-3"></i>
                    Months to be marked Paid ({{ previewMonths.length }})
                </p>
                <div class="flex flex-wrap gap-1.5">
                    <span ng-repeat="m in previewMonths"
                          class="px-2 py-1 bg-emerald-100 text-emerald-700 rounded-lg text-xs font-medium">
                        {{ m }}
                    </span>
                </div>
                <p class="text-xs text-emerald-600 mt-2">
                    Total: <strong>₱{{ (markPaidTarget.amount * previewMonths.length) | number:0 }}</strong>
                </p>
            </div>

        </div>

        <!-- Footer -->
        <div class="flex gap-3 px-6 py-4 border-t border-slate-100">
            <button ng-click="" class="flex-1 py-2.5 rounded-xl border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-all">
                Cancel
            </button>
            <button ng-click="" ng-disabled="!paidUntil"
                    class="flex-1 flex items-center justify-center gap-2 py-2.5 rounded-xl bg-green-600 hover:bg-green-700 disabled:opacity-50 text-white text-sm font-medium transition-all">
                <i data-lucide="calendar-check" class="w-4 h-4"></i>
                Confirm & Mark Paid
            </button>
        </div>
    </div>
</div>

