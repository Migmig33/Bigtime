@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<!-- Toast Notification -->
<div ng-show="toastShow" ng-cloak
     style="animation: slideDown 0.5s ease-in-out"
     class="fixed top-4 right-4 z-[100] flex items-center gap-3 bg-white border border-slate-200 shadow-sm rounded-2xl px-5 py-4 w-[400px] max-w-full transition-all duration-300">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-gray-900 shrink-0">
        <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 8a.75.75 0 00-1.5 0v4a.75.75 0 001.5 0V8zM12 16a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
    </svg>
    <span class="text-slate-800 font-medium text-[15px]">{{ toast.message }}</span>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/40" ng-show="deleteUnitConfirm" ng-cloak>
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm mx-4 p-6">
        <h2 class="text-slate-900 font-semibold text-base mb-2">Delete Unit</h2>
        <p class="text-slate-600 text-sm mb-5">Are you sure you want to delete this unit ({{selectedUnit}})? This action cannot be undone.</p>
        <div class="flex gap-3">
            <button ng-click="deleteUnitConfirm = false" class="flex-1 py-2.5 rounded-xl border border-slate-200 text-slate-700 text-sm hover:bg-slate-50 transition-all">Cancel</button>
            <button ng-click="deleteUnit(selectedUnit)" class="flex-1 py-2.5 rounded-xl bg-red-600 text-white text-sm hover:bg-red-700 transition-all">Delete</button>
        </div>
    </div>
</div>
<!-- Unit Editor Modal -->
<div id="editorModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4" ng-show="editorModal" ng-cloak>
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl max-h-[90vh] flex flex-col">
        <!-- Modal Header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <h2 id="modalTitle" class="text-slate-900 font-semibold text-base">Add New Unit</h2>
            <button ng-click="closeEditorModal()" class="p-1.5 rounded-lg hover:bg-slate-100 text-slate-400 hover:text-slate-600 transition-all">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <!-- Modal Body -->
        <div class="overflow-y-auto flex-1 min-h-0 p-6 space-y-5">
            <!-- Photos -->
            <div>
                <label class="block text-sm text-slate-700 font-medium mb-2">Photos (max 10)</label>
                <div class="flex gap-3 flex-wrap">
                    <div ng-repeat="img in imageUrls track by $index" class="relative w-28 h-20 rounded-xl overflow-hidden border border-slate-200 group">
                        <img ng-src="{{ img }}" class="w-full h-full object-cover" />
                        <button type="button" ng-click="removeImage($index)" class="absolute top-1 right-1 p-1 bg-red-500 text-white rounded-full opacity-0 group-hover:opacity-100 transition-opacity shadow-sm">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                        </button>
                    </div>
                    <label for="photoInput" ng-show="imageUrls.length < 10" ng-cloak class="w-28 h-20 rounded-xl border-2 border-dashed border-slate-200 hover:border-green-300 flex flex-col items-center justify-center gap-1 text-slate-400 hover:text-green-500 transition-all cursor-pointer">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                        <span class="text-xs">Add Photo</span>
                    </label>
                </div>
                <input type="file"
                       id="photoInput"
                       accept="image/*"
                       class="hidden"
                       onchange="angular.element(this).scope().handleImageUpload(this.files)" />
            </div>

            <!-- Fields Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Unit Name *</label>
                    <input type="text" ng-model="unitName" maxlength="50" placeholder="e.g. Studio A101"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                    <p class="text-[10px] text-right mt-1" ng-class="unitName.length >= 50 ? 'text-red-500 font-bold' : 'text-slate-400'">{{unitName.length || 0}}/50</p>
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Floor</label>
                    <input type="text" ng-model="floor" maxlength="10" placeholder="e.g. 3F"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                    <p class="text-[10px] text-right mt-1" ng-class="floor.length >= 10 ? 'text-red-500 font-bold' : 'text-slate-400'">{{floor.length || 0}}/10</p>
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Monthly Rent (₱) *</label>
                    <input type="number" ng-model="price" oninput="if(this.value.length > 9) this.value = this.value.slice(0, 9)"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                    <p class="text-[10px] text-right mt-1" ng-class="(price ? (price + '').length : 0) >= 9 ? 'text-red-500 font-bold' : 'text-slate-400'">{{ price ? (price + '').length : 0 }}/9</p>
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Size (m²)</label>
                    <input type="number" ng-model="sqm" oninput="if(this.value.length > 4) this.value = this.value.slice(0, 4)"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                    <p class="text-[10px] text-right mt-1" ng-class="(sqm ? (sqm + '').length : 0) >= 4 ? 'text-red-500 font-bold' : 'text-slate-400'">{{ sqm ? (sqm + '').length : 0 }}/4</p>
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Unit Type</label>
                    <select ng-model="beds" class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
                        <option value="Studio">Studio</option>
                        <option value="1 Bedroom">1 Bedroom</option>
                        <option value="2 Bedroom">2 Bedroom</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Status</label>
                    <select ng-model="status" class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm text-slate-700 font-medium mb-1">Max Occupants</label>
                    <input type="number" ng-model="maxOccupants" oninput="if(this.value.length > 2) this.value = this.value.slice(0, 2)" placeholder="e.g. 2"
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                    <p class="text-[10px] text-right mt-1" ng-class="(maxOccupants ? (maxOccupants + '').length : 0) >= 2 ? 'text-red-500 font-bold' : 'text-slate-400'">{{ maxOccupants ? (maxOccupants + '').length : 0 }}/2</p>
                </div>

                <div class="sm:col-span-2">
                    <label class="block text-sm text-slate-700 font-medium mb-1">Address</label>
                    <input type="text" ng-model="address" maxlength="150" placeholder="Full address..."
                           class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
                    <p class="text-[10px] text-right mt-1" ng-class="address.length >= 150 ? 'text-red-500 font-bold' : 'text-slate-400'">{{address.length || 0}}/150</p>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-sm text-slate-700 font-medium mb-1">Description</label>
                    <textarea rows="3" ng-model="description" maxlength="100" placeholder="Unit details..."
                              class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 resize-none"></textarea>
                    <p class="text-[10px] text-right mt-1" ng-class="description.length >= 100 ? 'text-red-500 font-bold' : 'text-slate-400'">{{description.length || 0}}/100</p>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-sm text-slate-700 font-medium mb-2">
                        Amenities
                    </label>

                    <div class="flex flex-wrap gap-2">
                        <button ng-repeat="amenity in amenityOptions"
                                type="button"
                                ng-click="amenity.selected = !amenity.selected"
                                class="px-3 py-1.5 rounded-full text-xs border transition-all focus:outline-none focus:ring-2 focus:ring-green-500"
                                ng-class="{
                                    'bg-green-600 text-white border-green-600': amenity.selected,
                                    'bg-slate-50 text-slate-600 border-slate-200 hover:border-green-300': !amenity.selected
                                }">
                            {{ amenity.name }}
                        </button>
                    </div>

                    <p class="text-[10px] text-slate-400 mt-1">
                        {{ selectedAmenities().length }} amenities selected
                    </p>
                </div>
            </div>

            <!-- Color -->
            <div>
                <label class="block text-sm text-slate-700 font-medium mb-2">Fallback Color</label>
                <div class="flex items-center gap-3">
                    <input type="color" ng-model="colorCode" class="w-10 h-10 rounded-lg cursor-pointer border border-slate-200" />
                    <span class="text-slate-500 text-sm font-mono uppercase">{{colorCode || '#1F6FEB'}}</span>
                </div>
            </div>
        </div>

        <!-- Modal Footer -->
        <div class="flex gap-3 justify-end px-6 py-4 border-t border-slate-100">
            <button ng-click="closeEditorModal()" class="px-4 py-2 rounded-xl text-sm text-slate-600 hover:bg-slate-100 border border-slate-200 transition-all">Cancel</button>
            <button ng-click="saveUnit(selectedUnit)" class="px-5 py-2 bg-green-600 hover:bg-green-700 text-white rounded-xl text-sm font-medium transition-all">Save Unit</button>
        </div>
    </div>
</div>

<!-- Page Content -->
<div class="p-6 overflow-y-auto flex-1" ng-init="currentPage = 'Unit'; getAllUnits()">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-slate-900 text-2xl font-bold">Units</h1>
            <p class="text-slate-500 text-sm">{{ totalUnits }} total units</p>
        </div>
        <button ng-click="editorModal = true" class="flex items-center gap-2 px-4 py-2.5 bg-green-600 hover:bg-green-700 text-white rounded-xl text-sm font-medium transition-all">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Add Unit
        </button>
    </div>

    <!-- Search + Sort -->
    <div class="flex gap-2 mb-3">
        <div class="relative flex-1">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" ng-model="searchQuery" placeholder="Search units..."
                   class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-green-500" />
        </div>
        <button ng-click="toggleSort()" class="flex items-center gap-1.5 px-3 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-600 hover:border-green-300 hover:text-green-700 text-sm font-medium transition-all">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="7" y1="12" x2="17" y2="12"></line><line x1="11" y1="18" x2="13" y2="18"></line></svg>
            <span class="hidden sm:inline">{{ sortAsc ? 'A → Z' : 'Z → A' }}</span>
        </button>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-y-2 gap-x-4 mb-3 p-3 bg-slate-50 border border-slate-100 rounded-2xl">
        <div class="flex items-center gap-2 flex-wrap">
            <span class="text-xs text-slate-400 font-medium">Status:</span>
            <button ng-repeat="s in ['All', 'active', 'inactive']" ng-click="setStatus(s)"
                    ng-class="statusFilter === s ? 'bg-green-600 text-white border-green-600' : 'bg-white text-slate-600 border-slate-200'"
                    class="px-3 py-1 rounded-lg text-xs font-medium border transition-all capitalize">
                {{s}}
            </button>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-left">
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium">Unit</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium">Type / Size</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium">Price</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium">Status</th>
                        <th class="px-5 py-3 text-xs text-slate-500 font-medium text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <tr ng-repeat="unit in filteredUnits()" class="hover:bg-slate-50 transition-colors">
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-3">
                                <img ng-if="unit.imageUrl" ng-src="{{ unit.imageUrl }}" class="w-10 h-8 rounded-lg object-cover" />
                                <div ng-if="!unit.imageUrl" class="w-10 h-8 rounded-lg" ng-style="{ 'background-color': unit.colorCode }"></div>
                                <div>
                                    <p class="text-slate-900 text-sm font-medium">{{ unit.unitName }}</p>
                                    <p class="text-slate-400 text-[11px]">{{ unit.floor }}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-5 py-3 text-sm text-slate-600">{{ unit.beds }} · {{ unit.sqm }}m²</td>
                        <td class="px-5 py-3 text-sm text-slate-900 font-medium">₱{{ unit.price | number:0 }}</td>
                        <td class="px-5 py-3">
                            <span class="px-2.5 py-1 rounded-full text-[11px] font-medium"
                                  ng-class="unit.status === 'active' ? 'bg-green-50 text-green-700' : 'bg-slate-100 text-slate-500'">
                                {{ unit.status === 'active' ? 'Active' : 'Inactive' }}
                            </span>
                        </td>
                        <!-- Actions -->
                        <td class="px-5 py-3">
                            <div class="flex items-center justify-end gap-2">
                                <!-- Edit Button -->
                                <button type="button"
                                        ng-click="triggerEditUnit(unit)"
                                        class="relative z-10 p-2 rounded-lg hover:bg-green-50 text-slate-400 hover:text-green-600 transition-all cursor-pointer">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                         class="pointer-events-none">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                    </svg>
                                </button>

                                <!-- Delete Button -->
                                <button type="button"
                                        ng-click="triggerConfirmDeleteUnit(unit.Uid)"
                                        class="relative z-10 p-2 rounded-lg hover:bg-red-50 text-slate-400 hover:text-red-600 transition-all cursor-pointer">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                         class="pointer-events-none">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                                        <line x1="10" y1="11" x2="10" y2="17"></line>
                                        <line x1="14" y1="11" x2="14" y2="17"></line>
                                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>