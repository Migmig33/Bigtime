@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}
<!-- Toast Notification -->
<div ng-show="toastShow"
     style="animation: slideDown 0.5s ease-in-out"
     class="fixed top-4 right-4 z-[100] flex items-center gap-3 bg-white border shadow-sm rounded-2xl px-5 py-4 w-[400px] max-w-full transition-all duration-300"
     ng-class="{
             'border-green-200': toast.type === 'success',
             'border-red-200': toast.type === 'error'
         }">
    <!-- Success Icon -->
    <svg ng-if="toast.type === 'success'" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-green-500 shrink-0">
        <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd" />
    </svg>
    <!-- Error Icon -->
    <svg ng-if="toast.type === 'error'" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-red-500 shrink-0">
        <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 8a.75.75 0 00-1.5 0v4a.75.75 0 001.5 0V8zM12 16a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
    </svg>
    <span class="font-medium text-[15px]"
          ng-class="{
                  'text-green-700': toast.type === 'success',
                  'text-red-700': toast.type === 'error'
              }">
        {{ toast.message }}
    </span>
</div>

<div class="min-h-screen bg-gradient-to-br from-slate-900 via-green-950 to-slate-800 flex items-center justify-center p-4 relative overflow-hidden">

    <!-- Background Blobs -->
    <div class="absolute -top-20 -left-20 w-96 h-96 bg-green-600/20 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-20 -right-20 w-96 h-96 bg-emerald-600/20 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative w-full max-w-md">

        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="w-14 h-14 bg-green-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-green-900/50">
                <svg class="w-7 h-7 fill-none stroke-white stroke-2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 21h18M3 7l9-4 9 4M4 21V7M20 21V7M9 21V12h6v9" />
                </svg>
            </div>
            <h1 class="text-3xl text-white font-light mb-1">GreenResidences</h1>
            <p class="text-slate-400 text-sm">Admin Portal</p>
        </div>

        <!-- Step 1: Credentials -->
        <div ng-show="step === 'credentials'" class="bg-white rounded-2xl p-8 shadow-2xl">

            <div class="mb-6">
                <h2 class="text-slate-900 text-xl font-semibold mb-1">Sign In</h2>
                <p class="text-slate-500 text-sm">Enter your admin credentials to continue.</p>
            </div>

            <!-- Email -->
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Email Address</label>
                <div class="relative">
                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none">
                        <svg class="w-4 h-4 fill-none stroke-slate-400 stroke-2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="20" height="16" x="2" y="4" rx="2" />
                            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                        </svg>
                    </span>
                    <input type="email" ng-model="email"
                           placeholder="admin@greenresidences.com"
                           required
                           class="w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all" />
                </div>
            </div>

            <!-- Password -->
            <div class="mb-4">
                <label class="block text-sm font-medium text-slate-700 mb-1.5">Password</label>
                <div class="relative">
                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none">
                        <svg class="w-4 h-4 fill-none stroke-slate-400 stroke-2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="18" height="11" x="3" y="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </span>
                    <input type="password" ng-model="password"
                           placeholder="Enter password"
                           required
                           class="w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all" />
                </div>
            </div>

            <!-- Sign In Button -->
            <button ng-click="authFunc()" ng-disabled="loading"
                    class="w-full flex items-center justify-center gap-2 py-3 bg-green-600 hover:bg-green-700 disabled:opacity-70 text-white rounded-xl text-sm font-medium transition-all focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 mt-2">
                <span ng-if="loading" class="inline-block w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                <span ng-if="!loading">Sign In</span>
                <span ng-if="loading">Signing in...</span>
            </button>

        </div>

        <!-- Step 2: OTP Verification -->
        <div ng-show="step === 'verify'" class="bg-white rounded-2xl p-8 shadow-2xl">

            <!-- Shield Icon -->
            <div class="flex justify-center mb-5">
                <div class="w-14 h-14 bg-green-100 rounded-2xl flex items-center justify-center">
                    <svg class="w-7 h-7 fill-none stroke-green-600 stroke-2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        <path d="m9 12 2 2 4-4" />
                    </svg>
                </div>
            </div>

            <!-- Header -->
            <div class="text-center mb-6">
                <h2 class="text-slate-900 text-xl font-semibold mb-1">Verify your email</h2>
                <p class="text-slate-500 text-sm">A 6-digit verification code was sent to</p>
                <p class="text-green-600 text-sm font-medium mt-0.5">{{ email }}</p>
            </div>

            <!-- OTP Inputs -->
            <div class="mb-5">
                <label class="block text-sm text-slate-700 font-medium mb-3 text-center">
                    Enter verification code
                </label>
                <div class="flex gap-2 justify-center">
                    <input type="text" maxlength="1" ng-model="otp[0]" ng-change="otpNext(0)" id="otp0"
                           class="w-11 h-[52px] text-center text-lg font-bold border-2 border-slate-200 rounded-xl focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 transition-all bg-slate-50 text-slate-900" />
                    <input type="text" maxlength="1" ng-model="otp[1]" ng-change="otpNext(1)" id="otp1"
                           class="w-11 h-[52px] text-center text-lg font-bold border-2 border-slate-200 rounded-xl focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 transition-all bg-slate-50 text-slate-900" />
                    <input type="text" maxlength="1" ng-model="otp[2]" ng-change="otpNext(2)" id="otp2"
                           class="w-11 h-[52px] text-center text-lg font-bold border-2 border-slate-200 rounded-xl focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 transition-all bg-slate-50 text-slate-900" />
                    <input type="text" maxlength="1" ng-model="otp[3]" ng-change="otpNext(3)" id="otp3"
                           class="w-11 h-[52px] text-center text-lg font-bold border-2 border-slate-200 rounded-xl focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 transition-all bg-slate-50 text-slate-900" />
                    <input type="text" maxlength="1" ng-model="otp[4]" ng-change="otpNext(4)" id="otp4"
                           class="w-11 h-[52px] text-center text-lg font-bold border-2 border-slate-200 rounded-xl focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 transition-all bg-slate-50 text-slate-900" />
                    <input type="text" maxlength="1" ng-model="otp[5]" ng-change="otpNext(5)" id="otp5"
                           class="w-11 h-[52px] text-center text-lg font-bold border-2 border-slate-200 rounded-xl focus:outline-none focus:border-green-500 focus:ring-2 focus:ring-green-200 transition-all bg-slate-50 text-slate-900" />
                </div>
            </div>

            <!-- Verify Button -->
            <button ng-click="verifyCode()" ng-disabled="loading"
                    class="w-full flex items-center justify-center gap-2 py-3 bg-green-600 hover:bg-green-700 disabled:opacity-60 text-white rounded-xl text-sm font-medium transition-all shadow-lg shadow-green-200 focus:outline-none focus:ring-2 focus:ring-green-500">
                <span ng-if="loading" class="inline-block w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                <span ng-if="!loading">Verify &amp; Continue</span>
                <span ng-if="loading">Verifying...</span>
            </button>

            <!-- Resend -->
            <div class="mt-4 text-center">
                <p class="text-slate-500 text-xs mb-2">Didn't receive the code?</p>
                <button ng-click="resend()" ng-disabled="resendCooldown > 0"
                        class="inline-flex items-center gap-1.5 text-sm text-green-600 hover:text-green-700 disabled:text-slate-400 disabled:cursor-not-allowed font-medium transition-colors">
                    <svg class="w-3.5 h-3.5 fill-none stroke-current stroke-2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                        <path d="M3 3v5h5" />
                    </svg>
                    <span ng-if="resendCooldown === 0">Resend code</span>
                    <span ng-if="resendCooldown > 0">Resend in {{ resendCooldown }}s</span>
                </button>
            </div>

            <!-- Back -->
            <button ng-click="step = 'credentials'; otp = []"
                    class="mt-4 w-full flex items-center justify-center gap-2 text-sm text-slate-500 hover:text-slate-700 transition-colors">
                <svg class="w-4 h-4 fill-none stroke-current stroke-2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m15 18-6-6 6-6" />
                </svg>
                Change credentials
            </button>

        </div>

    </div>
</div>
