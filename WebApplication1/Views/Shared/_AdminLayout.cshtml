<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body ng-app="app" ng-controller="controller">
    <style>
        :root {
            --font-size: 16px;
            --background: #ffffff; /* Pure white background */
            --foreground: #064e3b; /* Very dark green for main text */
            --primary: #16a34a; /* Vibrant Green (Tailwind green-600) for buttons & user bubbles */
            --primary-foreground: #ffffff; /* White text on green */
            --secondary: #dcfce7; /* Light mint green */
            --secondary-foreground: #14532d; /* Dark forest green */
            --muted: #f0fdf4; /* Very light green background for bot bubbles and header */
            --muted-foreground: #15803d; /* Medium green for subtext/icons */
            --accent: #dcfce7; /* Mint green for hover states */
            --accent-foreground: #16a34a;
            --destructive: #ef4444; /* Red for the unread notification badge */
            --destructive-foreground: #ffffff;
            --border: #bbf7d0; /* Soft green for borders */
            --input: transparent;
            --input-background: #ffffff; /* White background for the text input */
            --radius: 1rem;
        }
        [ng\:cloak], [ng-cloak], [data-ng-cloak], [x-ng-cloak], .ng-cloak, .x-ng-cloak {
            display: none !important;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(1px);
            }
        }
    </style>

    <div class="flex">
        <!-- Desktop Sidebar -->
        <div id="admin-sidebar" class="hidden sm:flex flex-col bg-slate-800 transition-all duration-300 flex-shrink-0 h-screen sticky top-0"
             ng-class="sidebarCollapsed ? 'w-16' : 'w-64'">

            <!-- Logo -->
            <div class="px-4 py-5 border-b border-slate-700 overflow-hidden">
                <div class="w-full h-16 rounded-xl overflow-hidden" ng-show="!sidebarCollapsed" ng-cloak>
                    <img src="https://i.imgur.com/Y6opN46.png"
                         alt="UnityRent Logo"
                         class="w-full h-full object-cover object-center" />
                </div>
                <!-- Collapsed icon -->
                <div ng-show="sidebarCollapsed" class="flex justify-center" ng-cloak>
                    <div class="w-9 h-9 bg-green-600 rounded-xl flex items-center justify-center">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" /><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" /><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" /></svg>
                    </div>
                </div>
            </div>

            <!-- Nav -->
            <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
                <button ng-click="goTo('Dashboard')"
                        class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all"
                        ng-class="currentPage == 'Dashboard' ? 'bg-green-600 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'"
                        title="Dashboard">
                    <svg class="flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                    <span ng-show="!sidebarCollapsed" ng-cloak>Dashboard</span>
                </button>

                <button ng-click="goTo('Units')"
                        class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all"
                        ng-class="currentPage == 'Unit' ? 'bg-green-600 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'"
                        title="Units">
                    <svg class="flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" /><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" /><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" /></svg>
                    <span ng-show="!sidebarCollapsed" ng-cloak>Units</span>
                </button>

                <button ng-click="goTo('Tenants')"
                        class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all"
                        ng-class="currentPage == 'Tenant' ? 'bg-green-600 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'"
                        title="Tenants">
                    <svg class="flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                    <span ng-show="!sidebarCollapsed" ng-cloak>Tenants</span>
                </button>

                <button ng-click="goTo('Bookings')"
                        class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all"
                        ng-class="currentPage == 'Bookings' ? 'bg-green-600 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'"
                        title="Bookings">
                    <svg class="flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    <span ng-show="!sidebarCollapsed" ng-cloak>Bookings</span>
                </button>

                <button ng-click="goTo('Maintenance')"
                        class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all"
                        ng-class="currentPage == 'Maintenance' ? 'bg-green-600 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'"
                        title="Maintenance">
                    <svg class="flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>
                    <span ng-show="!sidebarCollapsed" ng-cloak>Maintenance</span>
                </button>

                <button ng-click="goTo('Payments')"
                        class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all"
                        ng-class="currentPage == 'Payments' ? 'bg-green-600 text-white' : 'text-slate-300 hover:bg-slate-700 hover:text-white'"
                        title="Payments">
                    <svg class="flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" /><line x1="1" y1="10" x2="23" y2="10" /></svg>
                    <span ng-show="!sidebarCollapsed" ng-cloak>Payments</span>
                </button>
            </nav>

            <!-- Footer -->
            <div class="px-3 py-4 border-t border-slate-700 space-y-1">
                <button ng-click="sidebarCollapsed = !sidebarCollapsed"
                        class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-slate-400 hover:bg-slate-700 hover:text-white transition-all"
                        title="Toggle Sidebar">
                    <!-- Arrow flips when collapsed -->
                    <svg class="flex-shrink-0 transition-transform duration-300"
                         ng-class="sidebarCollapsed ? 'rotate-180' : ''"
                         width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                    <span ng-show="!sidebarCollapsed" ng-cloak>Collapse</span>
                </button>

                <button ng-click="goTo('Logout')"
                        class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-red-400 hover:bg-red-900/20 hover:text-red-300 transition-all"
                        title="Logout">
                    <svg class="flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                    <span ng-show="!sidebarCollapsed" ng-cloak>Logout</span>
                </button>

                <div class="flex items-center gap-2 px-3 py-2" ng-show="!sidebarCollapsed" ng-cloak>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-slate-400 flex-shrink-0">
                        <circle cx="12" cy="8" r="4" />
                        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                    </svg>
                    <p class="text-xs text-slate-400 font-medium tracking-widest uppercase">Admin Portal</p>
                </div>
            </div>
        </div>

        <!-- Mobile Bottom Nav -->
        <div class="sm:hidden fixed bottom-0 left-0 right-0 z-50 bg-slate-800 border-t border-slate-700 flex items-center justify-around px-2 py-2">
            <button ng-click="goTo('Dashboard')" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-xl transition-all" ng-class="currentPage == 'Dashboard' ? 'text-green-400' : 'text-slate-400 hover:text-white'">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                <span class="text-[10px]">Dashboard</span>
            </button>
            <button ng-click="goTo('Units')" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-xl transition-all" ng-class="currentPage == 'Unit' ? 'text-green-400' : 'text-slate-400 hover:text-white'">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" /><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" /><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" /></svg>
                <span class="text-[10px]">Units</span>
            </button>
            <button ng-click="goTo('Tenants')" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-xl transition-all" ng-class="currentPage == 'Tenant' ? 'text-green-400' : 'text-slate-400 hover:text-white'">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                <span class="text-[10px]">Tenants</span>
            </button>
            <button ng-click="goTo('Bookings')" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-xl transition-all" ng-class="currentPage == 'Booking' ? 'text-green-400' : 'text-slate-400 hover:text-white'">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                <span class="text-[10px]">Bookings</span>
            </button>
            <button ng-click="goTo('Maintenance')" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-xl transition-all" ng-class="currentPage == 'Maintenance' ? 'text-green-400' : 'text-slate-400 hover:text-white'">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>
                <span class="text-[10px]">Maintenance</span>
            </button>
            <button ng-click="goTo('Payments')" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-xl transition-all" ng-class="currentPage == 'Payment' ? 'text-green-400' : 'text-slate-400 hover:text-white'">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" /><line x1="1" y1="10" x2="23" y2="10" /></svg>
                <span class="text-[10px]">Payments</span>
            </button>
            <button ng-click="goTo('Admin-Logout')" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-xl text-red-400 hover:text-red-300 transition-all">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                <span class="text-[10px]">Logout</span>
            </button>
        </div>

        <div class="w-full min-w-0">
            @RenderBody()
        </div>

        <div class="fixed bottom-6 right-6 z-50 flex flex-col items-end pointer-events-none" ng-init="chatOpen = false; unread = 0">

            <div class="fixed bottom-6 right-6 z-50 flex flex-col items-end pointer-events-none" ng-init="chatOpen = false; unread = 0" ng-cloak>

                <!-- Chat Window -->
                <!-- FIX: Added 'opacity-0 scale-50 pointer-events-none' directly to the base class so it starts hidden before Angular loads -->
                <div class="bg-[var(--background)] w-80 sm:w-[400px] rounded-2xl shadow-2xl border border-[var(--border)] flex flex-col mb-4 overflow-hidden transition-all duration-300 origin-bottom-right opacity-0 scale-50 pointer-events-none"
                     ng-class="chatOpen ? 'opacity-100 scale-100 pointer-events-auto' : 'opacity-0 scale-50 pointer-events-none'"
                     style="height: 600px; max-height: 75vh;">

                    <!-- Header -->
                    <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--border)] bg-[var(--background)] z-10">
                        <div>
                            <h1 class="text-[var(--foreground)] font-semibold text-sm">GreenBot</h1>
                            <p class="text-[var(--muted-foreground)] text-xs">AI Data Assistant</p>
                        </div>
                        <button ng-click="clearChat()" class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border border-[var(--border)] text-[var(--muted-foreground)] hover:text-[var(--foreground)] hover:bg-[var(--accent)] text-xs transition-all focus:outline-none focus:ring-2 focus:ring-[var(--primary)]">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /></svg>
                            Clear
                        </button>
                    </div>

                    <!-- Quick Suggestions -->
                    <div class="px-5 py-3 border-b border-[var(--border)] bg-[var(--muted)]">
                        <p class="text-[11px] text-[var(--muted-foreground)] mb-2 uppercase font-semibold tracking-wider">Quick queries</p>
                        <div class="flex flex-wrap gap-2">
                            <button ng-repeat="suggestion in adminSuggestions"
                                    ng-click="sendMessage(suggestion)"
                                    class="text-xs px-3 py-1.5 bg-[var(--background)] text-[var(--foreground)] rounded-full border border-[var(--border)] hover:bg-[var(--accent)] transition-colors">
                                <span ng-bind="suggestion"></span>
                            </button>
                        </div>
                    </div>

                    <!-- Messages Area -->
                    <div id="chat-scroll-area" class="flex-1 overflow-y-auto p-5 space-y-4 bg-[var(--background)]">
                        <div ng-repeat="msg in chatMessages" class="flex gap-3" ng-class="msg.sender === 'user' ? 'justify-end' : 'justify-start'">

                            <!-- Bot Avatar -->
                            <div ng-show="msg.sender === 'bot'" class="w-8 h-8 bg-[var(--accent)] rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" ng-cloak>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--primary)]"><rect x="3" y="11" width="18" height="10" rx="2" /><circle cx="12" cy="5" r="2" /><path d="M12 7v4" /><line x1="8" y1="16" x2="8" y2="16" /><line x1="16" y1="16" x2="16" y2="16" /></svg>
                            </div>

                            <!-- Message Bubble -->
                            <div class="max-w-[75%] rounded-2xl px-4 py-3 text-sm"
                                 ng-class="msg.sender === 'user' ? 'bg-[var(--primary)] text-[var(--primary-foreground)] rounded-br-sm' : 'bg-[var(--muted)] text-[var(--foreground)] border border-[var(--border)] rounded-bl-sm'">
                                <span ng-bind="msg.text"></span>
                                <div class="text-[10px] mt-1 opacity-70" ng-class="msg.sender === 'user' ? 'text-[var(--primary-foreground)]' : 'text-[var(--muted-foreground)]'">
                                    <span ng-bind="msg.time | date:'shortTime'"></span>
                                </div>
                            </div>

                            <!-- User Avatar -->
                            <div ng-show="msg.sender === 'user'" class="w-8 h-8 bg-[var(--accent)] rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" ng-cloak>
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--primary)]"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                            </div>
                        </div>

                        <!-- Typing Indicator -->
                        <div ng-show="isBotTyping" class="flex gap-3 items-start" ng-cloak>
                            <div class="w-8 h-8 bg-[var(--accent)] rounded-full flex items-center justify-center flex-shrink-0">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--primary)]"><rect x="3" y="11" width="18" height="10" rx="2" /><circle cx="12" cy="5" r="2" /><path d="M12 7v4" /></svg>
                            </div>
                            <div class="bg-[var(--muted)] border border-[var(--border)] rounded-2xl rounded-bl-sm px-4 py-4 flex gap-1 items-center">
                                <span class="w-1.5 h-1.5 bg-[var(--muted-foreground)] rounded-full animate-bounce" style="animation-delay: 0ms"></span>
                                <span class="w-1.5 h-1.5 bg-[var(--muted-foreground)] rounded-full animate-bounce" style="animation-delay: 150ms"></span>
                                <span class="w-1.5 h-1.5 bg-[var(--muted-foreground)] rounded-full animate-bounce" style="animation-delay: 300ms"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Input Area -->
                    <div class="p-4 border-t border-[var(--border)] bg-[var(--background)]">
                        <form ng-submit="sendMessage()" class="flex gap-2">
                            <input type="text" ng-model="userMessage" placeholder="Ask about your rental data..."
                                   class="flex-1 px-4 py-2.5 rounded-xl border border-[var(--border)] bg-[var(--input-background)] text-[var(--foreground)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--primary)]" />
                            <button type="submit" ng-disabled="!userMessage"
                                    class="px-4 py-2.5 bg-[var(--primary)] hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed text-[var(--primary-foreground)] rounded-xl transition-all focus:outline-none focus:ring-2 focus:ring-[var(--primary)]">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Floating Chat Toggle Button -->
                <!-- FIX: Added default bg/text colors to standard class so it doesn't render gray for a split second -->
                <button ng-click="chatOpen = !chatOpen; unread = 0"
                        class="w-14 h-14 rounded-full shadow-xl flex items-center justify-center transition-all duration-300 focus:outline-none hover:scale-105 active:scale-95 relative pointer-events-auto bg-[var(--primary)] text-[var(--primary-foreground)]"
                        ng-class="chatOpen ? 'bg-[var(--muted)] text-[var(--foreground)] border border-[var(--border)]' : 'bg-[var(--primary)] text-[var(--primary-foreground)] hover:opacity-90'">

                    <!-- Unread Badge -->
                    <span ng-show="!chatOpen && unread > 0" class="absolute -top-1 -right-1 w-5 h-5 bg-[var(--destructive)] text-[var(--destructive-foreground)] text-[10px] font-bold rounded-full flex items-center justify-center shadow-sm z-10 border-2 border-[var(--background)]" ng-cloak>
                        {{unread}}
                    </span>

                    <!-- Bot Icon (Shows when closed) -->
                    <svg ng-show="!chatOpen" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" ng-cloak><rect x="3" y="11" width="18" height="10" rx="2" /><circle cx="12" cy="5" r="2" /><path d="M12 7v4" /><line x1="8" y1="16" x2="8" y2="16" /><line x1="16" y1="16" x2="16" y2="16" /></svg>

                    <!-- Close Icon (Shows when open) -->
                    <svg ng-show="chatOpen" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" ng-cloak><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>

    </div><!-- Floating GreenBot Widget -->
  
    <script src="~/Scripts/jquery-3.7.0.min.js"></script>
    <script src="~/Scripts/angular.min.js"></script>
    <script src="~/Scripts/Scripts/Module.js"></script>
    <script src="~/Scripts/Scripts/Service.js"></script>
    <script src="~/Scripts/Scripts/Controller.js"></script>
    <script src="~/Scripts/Chart.min.js"></script>
    <script src="~/Scripts/angular-chart.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</body>
</html>